def Gen.genP (self : GenState) (e : IRExpr) (ctx : Effect) (depth : Float) : String :=
  let s : String := genExpr self e ctx depth
  if needsParens e then
    s!"({s})"
  else
    s

def Gen.genMatch (self : GenState) (e : String) (ctx : Effect) (depth : Float) : String :=
  let scrutinee : String := genExpr self e.scrutinee ctx depth
  let inner : String := "  ".repeat (depth + 1)
  let cases : Array String := e.cases.map (fun c => let pat : String := genPat self c.pattern
  let guard : String := if c.guard then
    " if " ++ (genExpr self c.guard ctx depth)
  else
    ""
  let body : String := genExpr self c.body ctx (depth + 1)
  s!"{inner}| {pat}{guard} => {body}")
  (s!"match {scrutinee} with
  ") ++ (cases.join "\n")

def Gen.genPat (self : GenState) (p : IRPattern) : String :=
  match p.tag with
    | "PVar" => sanitize p.name
    | "PWild" => "_"
    | "PLit" => if (TSLean.typeOf p.value) == "string" then
      serialize p.value
    else
      String p.value
    | "PString" => serialize p.value
    | "PNone" => ".none"
    | "PSome" => ".some " ++ (genPat self p.inner)
    | "PCtor" => let localName : String := if p.ctor.includes "." then
      p.ctor.split ".".back?
    else
      p.ctor
    let args : Array String := p.args.map (fun a => genPat self a)
    if args.size == 0 then
      s!".{localName}"
    else
      (s!".{localName} ") ++ (args.join " ")
    | "PTuple" => ("(" ++ (p.elems.map (fun x => genPat self x).join ", ")) ++ ")"
    | "PStruct" => ("{ " ++ (p.fields.map (fun f => (s!"{f.name} := ") ++ (genPat self f.pattern)).join ", ")) ++ " }"
    | "POr" => p.pats.map (fun x => genPat self x).join " | "
    | "PAs" => ((genPat self p.pattern) ++ " as ") ++ p.name
    | _ => "_"

def Gen.genDoBlock (self : GenState) (stmts : Array DoStmt) (ctx : Effect) (depth : Float) : String :=
  let ind : String := "  ".repeat (depth + 1)
  let lines : Array String := #["do"]
  Array.forM stmts (fun s => match s.tag with
    | "DoBind" => lines.push ((s!"{ind}let {s.name} ← ") ++ (genExpr self s.expr ctx (depth + 1)))
    | "DoLet" => lines.push ((s!"{ind}let {s.name} := ") ++ (genExpr self s.value ctx (depth + 1)))
    | "DoExpr" => lines.push (ind ++ (genExpr self s.expr ctx (depth + 1)))
    | "DoReturn" => lines.push ((s!"{ind}return ") ++ (genExpr self s.value ctx (depth + 1))))
  lines.join "\n"

def Gen.genDoSeq (self : GenState) (stmts : Array IRExpr) (ctx : Effect) (depth : Float) : String :=
  let ind : String := "  ".repeat (depth + 1)
  let lines : Array String := #["do"]
  Array.forM stmts (fun s => if s.tag == "Bind" then
    lines.push ((s!"{ind}let {s.name} ← ") ++ (genExpr self s.monad ctx (depth + 1)))
  else
    if s.tag == "Let" then
      lines.push ((s!"{ind}let {s.name} := ") ++ (genExpr self s.value ctx (depth + 1)))
    else
      if s.tag == "Return" then
        lines.push ((s!"{ind}return ") ++ (genExpr self s.value ctx (depth + 1)))
      else
        lines.push (ind ++ (genExpr self s ctx (depth + 1))))
  lines.join "\n"

def Gen.genBinOp (self : GenState) (e : String) (ctx : Effect) (depth : Float) : String :=
  if e.op == "NullCoalesce" then
    let l : String := genP self e.left ctx depth
    let r : String := genP self e.right ctx depth
    s!"Option.getD {l} {r}"
  else
    if (e.op == "Eq") && ((e.right.tag == "LitNull") || ((e.right.tag == "Var") && (e.right.name == "none"))) then
      let l : String := genP self e.left ctx depth
      s!"{l}.isNone"
    else
      if (e.op == "Ne") && ((e.right.tag == "LitNull") || ((e.right.tag == "Var") && (e.right.name == "none"))) then
        let l : String := genP self e.left ctx depth
        s!"{l}.isSome"
      else
        if (e.op == "Concat") || ((e.op == "Add") && (e.left.type.tag == "String")) then
          let interp : Option String := trySInterp self e ctx depth
          if interp then
            interp
          else
            ()
        else
          ()
        let l : String := genP self e.left ctx depth
        let r : String := genP self e.right ctx depth
        let op : String := translateBinOp e.op e.left.type
        s!"{l} {op} {r}"

def Gen.trySInterp (self : GenState) (e : IRExpr) (ctx : Effect) (depth : Float) : Option String :=
  let parts : Option (Array IRExpr) := flattenConcat e
  if !parts then
    none
  else
    let hasInterp : Bool := parts.some (fun p => p.tag != "LitString")
    let hasLiteral : Bool := parts.some (fun p => (p.tag == "LitString") && (p.value != ""))
    if (!hasInterp) || (!hasLiteral) then
      none
    else
      if !(parts.every isSafeInterp) then
        none
      else
        let hasUnsafeChars : Bool := parts.some (fun p => (p.tag == "LitString") && (default.test p.value))
        if hasUnsafeChars then
          none
        else
          let inner : String := parts.map (fun p => if p.tag == "LitString" then
            p.value
          else
            ("{" ++ (genExpr self p ctx depth)) ++ "}").join ""
          ("s!\"" ++ inner) ++ "\""

def Gen.tryOptionMatch (self : GenState) (e : String) (ctx : Effect) (depth : Float) (indent : String) : StateT GenState IO (Option String) :=
  do
    let cond : IRExpr := e.cond
    let optVar : Option String := none
    let optVarExpr : String := none
    do
      if ((cond.tag == "BinOp") && (cond.op == "Eq")) && ((cond.right.tag == "LitNull") || ((cond.right.tag == "Var") && (cond.right.name == "none"))) then
        if cond.left.tag == "Var" then
          do
            let optVar := cond.left.name
            let optVarExpr := cond.left
        else
          ()
      else
        ()
      do
        if (((!optVar) && (cond.tag == "BinOp")) && (cond.op == "Ne")) && ((cond.right.tag == "LitNull") || ((cond.right.tag == "Var") && (cond.right.name == "none"))) then
          if cond.left.tag == "Var" then
            do
              let optVar := cond.left.name
              do
                let optVarExpr := cond.left
                let inner := "  ".repeat (depth + 1)
          else
            ()
        else
          ()
        if !optVar then
          pure none
        else
          let thenIsNone : Bool := (((e.then.tag == "LitNull") || (e.then.tag == "LitUnit")) || ((e.then.tag == "Var") && (e.then.name == "none"))) || ((e.then.tag == "Return") && ((e.then.value.tag == "LitNull") || ((e.then.value.tag == "Var") && (e.then.value.name == "none"))))
          if !thenIsNone then
            pure none
          else
            let inner : String := "  ".repeat (depth + 1)
            let someBody : String := genExprWithVarSubst self e.else_ ctx (depth + 1) optVar "_v"
            pure (s!"match {optVar} with
    {inner}| none => none
    {inner}| some _v => {someBody}")

def Gen.genExprWithVarSubst (self : GenState) (e : IRExpr) (ctx : Effect) (depth : Float) (from : String) (to : String) : String :=
  let result : String := genExpr self e ctx depth
  result.replace RegExp (("\\b" ++ «from») ++ "\\b") "g" to

def Gen.emitComment (self : GenState) (c : String) : Unit :=
  Array.forM (c.split "\n") (fun line => let stripped : String := line.replace default "".replace default "".replace default "".trim
  if !stripped then
    ()
  else
    ()
  if stripped.startsWith "@" then
    ()
  else
    ()
  emit self (s!"-- {stripped}"))

def Gen.emit (self : GenState) (s : String) : Unit :=
  let prefix : String := "  ".repeat self.ind
  Array.forM (s.split "\n") (fun line => self.lines.push (prefix ++ line))

def LEAN_KWS : AssocSet String := AssocSet.empty

def sanitize (name : String) : String :=
  if LEAN_KWS.has name then
    s!"«{name}»"
  else
    name.replace default "_"

/-- Format type parameters as implicit ({T : Type}) — used for function definitions. -/
def fmtTPs (params : Array String) : String :=
  if params.size == 0 then
    ""
  else
    (" {" ++ (params.map (fun p => s!"{p} : Type").join "} {")) ++ "}"

/-- Format type parameters as explicit ((T : Type)) — used for structures and inductives. Explicit params let Lean infer type args at use sites without `(T := ...)` annotations. -/
def fmtExplicitTPs (params : Array String) : String :=
  if params.size == 0 then
    ""
  else
    " " ++ (params.map (fun p => s!"({p} : Type)").join " ")

/-- Determine if an expression body needs `do` wrapping when inside an effectful function. Returns true when the body contains monadic operations (Bind/Await/Sequence with effects) that aren't already inside a DoBlock. -/
partial def needsDoWrapping (body : IRExpr) : Bool :=
  match body.tag with
    | "DoBlock" => false
    | "Bind" => true
    | "Await" => true
    | "Sequence" => true
    | "Let" => needsDoWrapping body.body
    | "IfThenElse" => (needsDoWrapping body.then) || (needsDoWrapping body.else_)
    | _ => false


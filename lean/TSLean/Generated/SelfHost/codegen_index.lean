def Gen.emitNamespace (self : GenState) (d : String) : Unit :=
  emit self (s!"namespace {d.name}")
  emit self ""
  let funcNames : AssocSet String := AssocSet.empty
  let hasForwardRefs : Bool := d.decls.some (fun x => ((x.tag == "FuncDef") && (funcNames.size > 1)) && (bodyContainsAnyVarRef x.body funcNames x.name))
  if hasForwardRefs && (funcNames.size > 1) then
    Array.forM d.decls (fun x => if x.tag != "FuncDef" then
      emitDecl self x
      emit self ""
    else
      ())
    emit self "mutual"
    emit self ""
    Array.forM d.decls (fun x => if x.tag == "FuncDef" then
      emitDecl self x
      emit self ""
    else
      ())
    emit self "end"
  else
    Array.forM d.decls (fun x => emitDecl self x
    emit self "")
  emit self (s!"end {d.name}")


def emitNamespace (self : GenState) (d : String) : Unit :=
  self.emit (s!"namespace {d.name}")
    self.emit ""
    let groups : Array (Array IRDecl) := groupMutual d.decls
    Array.forM groups (fun group => if group.size == 1 then
      self.emitDecl group.getD 0 default
      self.emit ""
    else
      self.emit "mutual"
      self.emit ""
      Array.forM group (fun x => self.emitDecl x
      self.emit "")
      self.emit "end"
      self.emit "")
    self.emit (s!"end {d.name}")


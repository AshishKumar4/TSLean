def genMatch (self : GenState) (e : String) (ctx : Effect) (depth : Float) : String :=
  let scrutinee : String := self.genExpr e.scrutinee ctx depth
    let inner : String := "  ".repeat ((self.ind + depth) + 1)
    let cases : Array String := e.cases.map (fun c => let pat : String := self.genPat c.pattern
    let guard : String := if c.guard then
      " if " ++ (self.genExpr c.guard ctx depth)
    else
      ""
    let body : String := self.genExpr c.body ctx (depth + 1)
    s!"{inner}| {pat}{guard} => {body}")
    (s!"match {scrutinee} with
  ") ++ (cases.join "\n")

def genPat (self : GenState) (p : IRPattern) : String :=
  match p.tag with
      | "PVar" => sanitize p.name
      | "PWild" => "_"
      | "PLit" => if (TSLean.typeOf p.value) == "string" then
        serialize p.value
      else
        String p.value
      | "PString" => serialize p.value
      | "PNone" => ".none"
      | "PSome" => ".some " ++ (self.genPat p.inner)
      | "PCtor" => let localName : String := if p.ctor.includes "." then
        p.ctor.split ".".back?
      else
        p.ctor
      let args : Array String := p.args.map (fun a => self.genPat a)
      if args.size == 0 then
        s!".{localName}"
      else
        (s!".{localName} ") ++ (args.join " ")
      | "PTuple" => ("(" ++ (p.elems.map (fun x => self.genPat x).join ", ")) ++ ")"
      | "PStruct" => ("{ " ++ (p.fields.map (fun f => (s!"{f.name} := ") ++ (self.genPat f.pattern)).join ", ")) ++ " }"
      | "POr" => p.pats.map (fun x => self.genPat x).join " | "
      | "PAs" => ((self.genPat p.pattern) ++ " as ") ++ p.name
      | _ => "_"

def genDoBlock (self : GenState) (stmts : Array DoStmt) (ctx : Effect) (depth : Float) : String :=
  let ind : String := "  ".repeat ((self.ind + depth) + 1)
    let lines : Array String := #["do"]
    Array.forM stmts (fun s => match s.tag with
      | "DoBind" => lines.push ((s!"{ind}let {s.name} ← ") ++ (self.genExpr s.expr ctx (depth + 1)))
      | "DoLet" => lines.push ((s!"{ind}let {s.name} := ") ++ (self.genExpr s.value ctx (depth + 1)))
      | "DoExpr" => lines.push (ind ++ (self.genExpr s.expr ctx (depth + 1)))
      | "DoReturn" => lines.push ((s!"{ind}return ") ++ (self.genExpr s.value ctx (depth + 1))))
    lines.join "\n"

def genDoSeq (self : GenState) (stmts : Array IRExpr) (ctx : Effect) (depth : Float) : String :=
  let ind : String := "  ".repeat ((self.ind + depth) + 1)
    let lines : Array String := #["do"]
    Array.forM stmts (fun s => if s.tag == "Bind" then
      lines.push ((s!"{ind}let {s.name} ← ") ++ (self.genExpr s.monad ctx (depth + 1)))
    else
      if s.tag == "Let" then
        lines.push ((s!"{ind}let {s.name} := ") ++ (self.genExpr s.value ctx (depth + 1)))
      else
        if s.tag == "Return" then
          lines.push ((s!"{ind}return ") ++ (self.genExpr s.value ctx (depth + 1)))
        else
          lines.push (ind ++ (self.genExpr s ctx (depth + 1))))
    lines.join "\n"

def genBinOp (self : GenState) (e : String) (ctx : Effect) (depth : Float) : String :=
  if e.op == "NullCoalesce" then
      let l : String := self.genP e.left ctx depth
      let r : String := self.genP e.right ctx depth
      s!"Option.getD {l} {r}"
    else
      if (e.op == "Eq") && ((e.right.tag == "LitNull") || ((e.right.tag == "Var") && (e.right.name == "none"))) then
        let l : String := self.genP e.left ctx depth
        s!"{l}.isNone"
      else
        if (e.op == "Ne") && ((e.right.tag == "LitNull") || ((e.right.tag == "Var") && (e.right.name == "none"))) then
          let l : String := self.genP e.left ctx depth
          s!"{l}.isSome"
        else
          if (e.op == "Concat") || ((e.op == "Add") && (e.left.type.tag == "String")) then
            let interp : Option String := self.trySInterp e ctx depth
            if interp then
              interp
            else
              ()
          else
            ()
          let l : String := self.genP e.left ctx depth
          let r : String := self.genP e.right ctx depth
          let op : String := translateBinOp e.op e.left.type
          s!"{l} {op} {r}"

def trySInterp (self : GenState) (e : IRExpr) (ctx : Effect) (depth : Float) : Option String :=
  let parts : Option (Array IRExpr) := flattenConcat e
    if !parts then
      none
    else
      let hasInterp : Bool := parts.some (fun p => p.tag != "LitString")
      let hasLiteral : Bool := parts.some (fun p => (p.tag == "LitString") && (p.value != ""))
      if (!hasInterp) || (!hasLiteral) then
        none
      else
        if !(parts.every isSafeInterp) then
          none
        else
          let inner : String := parts.map (fun p => if p.tag == "LitString" then
            p.value.replace default "\\{"
          else
            ("{" ++ (self.genExpr p ctx depth)) ++ "}").join ""
          s!"s!"{inner}""

def tryOptionMatch (self : GenState) (e : String) (ctx : Effect) (depth : Float) (indent : String) : StateT GenState IO (Option String) :=
  do
    let cond : IRExpr := e.cond
      let optVar : Option String := none
      let optVarExpr : String := none
      do
        if ((cond.tag == "BinOp") && (cond.op == "Eq")) && ((cond.right.tag == "LitNull") || ((cond.right.tag == "Var") && (cond.right.name == "none"))) then
          if cond.left.tag == "Var" then
            do
              let optVar := cond.left.name
              let optVarExpr := cond.left
          else
            ()
        else
          ()
        do
          if (((!optVar) && (cond.tag == "BinOp")) && (cond.op == "Ne")) && ((cond.right.tag == "LitNull") || ((cond.right.tag == "Var") && (cond.right.name == "none"))) then
            if cond.left.tag == "Var" then
              do
                let optVar := cond.left.name
                do
                  let optVarExpr := cond.left
                  let inner := "  ".repeat ((self.ind + depth) + 1)
            else
              ()
          else
            ()
          if !optVar then
            pure none
          else
            let thenIsNone : Bool := (((e.then.tag == "LitNull") || (e.then.tag == "LitUnit")) || ((e.then.tag == "Var") && (e.then.name == "none"))) || ((e.then.tag == "Return") && ((e.then.value.tag == "LitNull") || ((e.then.value.tag == "Var") && (e.then.value.name == "none"))))
            if !thenIsNone then
              pure none
            else
              let inner : String := "  ".repeat ((self.ind + depth) + 1)
              let someBody : String := self.genExprWithVarSubst e.else_ ctx (depth + 1) optVar "_v"
              pure (s!"match {optVar} with
    {inner}| none => none
    {inner}| some _v => {someBody}")

def genExprWithVarSubst (self : GenState) (e : IRExpr) (ctx : Effect) (depth : Float) (from : String) (to : String) : String :=
  let result : String := self.genExpr e ctx depth
    result.replace RegExp (s!"\b{«from»}\b") "g" to

def emitComment (self : GenState) (c : String) : Unit :=
  Array.forM (c.split "\n") (fun line => let stripped : String := line.replace default "".replace default "".replace default "".trim
    if !stripped then
      ()
    else
      ()
    if stripped.startsWith "@" then
      ()
    else
      ()
    self.emit (s!"-- {stripped}"))

def emit (self : GenState) (line : String) : Unit :=
  let prefix : String := "  ".repeat self.ind
    Array.forM (line.split "\n") (fun l => self.lines.push (prefix ++ l))

def LEAN_KWS : AssocSet String := AssocSet.empty

def sanitize (name : String) : String :=
  if LEAN_KWS.has name then
      s!"«{name}»"
    else
      name.replace default "_"

/-- Format type parameters as implicit ({T : Type}) — used for function definitions. -/
def fmtTPs (params : Array String) : String :=
  if params.size == 0 then
      ""
    else
      (" {" ++ (params.map (fun p => s!"{p} : Type").join "} {")) ++ "}"

/-- Format type parameters as explicit ((T : Type)) — used for structures and inductives. Explicit params let Lean infer type args at use sites without `(T := ...)` annotations. -/
def fmtExplicitTPs (params : Array String) : String :=
  if params.size == 0 then
      ""
    else
      " " ++ (params.map (fun p => s!"({p} : Type)").join " ")

/-- Determine if an expression body needs `do` wrapping when inside an effectful function. Returns true when the body contains monadic operations (Bind/Await/Sequence with effects) that aren't already inside a DoBlock. -/
partial def needsDoWrapping (body : IRExpr) : Bool :=
  match body.tag with
      | "DoBlock" => false
      | "Bind" => true
      | "Await" => true
      | "Sequence" => true
      | "Let" => needsDoWrapping body.body
      | "IfThenElse" => (needsDoWrapping body.then) || (needsDoWrapping body.else_)
      | _ => false

/-- Emit a type-appropriate default value instead of sorry. Uses `default` (requires Inhabited instance) for most types, but emits concrete literals for common types. -/
partial def defaultForType (t : IRType) : String :=
  match t.tag with
      | "Nat" => "0"
      | "Int" => "0"
      | "Float" => "(0 : Float)"
      | "String" => "\"\""
      | "Bool" => "false"
      | "Unit" => "()"

    s!"({s})"
  else
    s
  let alreadyIO : Bool := (retLean.startsWith "IO ") || (retLean == "IO")
  let innerRet : String := if alreadyIO then
    retLean.replace default "".replace default "".replace default ""
  else
    retLean
  let effectiveRet : String := if alreadyIO then
    innerRet
  else
    retLean
  match eff.tag with
    | "Pure" => retLean
    | "IO" => if alreadyIO then
      retLean
    else
      "IO " ++ (w retLean)
    | "Async" => if alreadyIO then
      retLean
    else
      "IO " ++ (w retLean)
    | "State" => (("StateT " ++ (w (irTypeToLean eff.stateType))) ++ " IO ") ++ (w effectiveRet)
    | "Except" => (("ExceptT " ++ (w (irTypeToLean eff.errorType))) ++ " IO ") ++ (w effectiveRet)
    | "Combined" => let ms : String := monadString eff
    if (ms == "IO") && alreadyIO then
      retLean
    else
      (s!"{ms} ") ++ (w effectiveRet)


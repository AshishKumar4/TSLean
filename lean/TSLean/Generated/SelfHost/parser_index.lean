def cap (s : String) : String :=
  if s.isEmpty then s
  else String.mk (s.toList.head!.toUpper :: s.toList.tail!)

def fileToModuleName (filePath : String) : String :=
  let base := filePath.replace ".ts" "" |>.replace ".js" "" |>.replace ".tsx" ""
  "TSLean.Generated." ++ ".".intercalate (base.splitOn "/" |>.filter (· != "") |>.map cap)

def hasDOPattern (source : String) : Bool :=
  source.includes "DurableObjectState" || source.includes "state.storage"

def seq (a b : IRExpr) : IRExpr :=
  if a.tag == "LitUnit" then b else if b.tag == "LitUnit" then a else seqE #[a, b]

def branchReturns (e : IRExpr) : Bool := e.tag == "Return" || e.tag == "Throw"

def exprToPat (e : IRExpr) : IRPattern :=
  if e.tag == "LitString" then .PString e.value
  else if e.tag == "LitNat" then .PLit e.value
  else if e.tag == "LitBool" then .PLit e.value
  else if e.tag == "LitNull" then .PNone
  else if e.tag == "Var" then .PVar e.name
  else .PWild

def isCompoundAssign (kind : SyntaxKind) : Bool :=
  kind == .PlusEqualsToken || kind == .MinusEqualsToken ||
  kind == .AsteriskEqualsToken || kind == .SlashEqualsToken || kind == .PercentEqualsToken

def compoundOp : SyntaxKind → String
  | .PlusEqualsToken => "Add" | .MinusEqualsToken => "Sub"
  | .AsteriskEqualsToken => "Mul" | .SlashEqualsToken => "Div"
  | .PercentEqualsToken => "Mod" | _ => "Add"

def tsBinOp : SyntaxKind → String
  | .PlusToken => "Add" | .MinusToken => "Sub" | .AsteriskToken => "Mul"
  | .SlashToken => "Div" | .PercentToken => "Mod"
  | .EqualsEqualsToken | .EqualsEqualsEqualsToken => "Eq"
  | .ExclamationEqualsToken | .ExclamationEqualsEqualsToken => "Ne"
  | .LessThanToken => "Lt" | .LessThanEqualsToken => "Le"
  | .GreaterThanToken => "Gt" | .GreaterThanEqualsToken => "Ge"
  | .AmpersandAmpersandToken => "And" | .BarBarToken => "Or"
  | .AmpersandToken => "BitAnd" | .BarToken => "BitOr" | .CaretToken => "BitXor"
  | _ => "Add"


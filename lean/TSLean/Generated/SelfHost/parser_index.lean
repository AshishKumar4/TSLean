mutual

partial def parseParams (ctx : ParserCtxState) (params : Array Node) : Array IRParam :=
  params.map fun p =>
    let name := p.name.map Node.text |>.getD "_"
    let ty := mapType (ctx.checker.getTypeAtLocation p) ctx.checker
    { name, type := ty, implicit := some false,
      default_ := p.initializer.map (fun init => toString (repr (parseExpr ctx init))) }

partial def parseExpr (ctx : ParserCtxState) (node : Node) : IRExpr :=
  if isIdentifier node then
    if node.text == "this" then varE "self"
    else if node.text == "undefined" || node.text == "null" then litNull
    else varE node.text
  else if isStringLiteral node then litStr node.text
  else if isNumericLiteral node then litFloatE (node.text.toNat?.getD 0 |>.toFloat)
  else if node.kind == .TrueKeyword then litBoolE true
  else if node.kind == .FalseKeyword then litBoolE false
  else if node.kind == .NullKeyword then litNull
  else if isPropertyAccessExpression node then
    fieldAcc (node.expression.map (parseExpr ctx) |>.getD hole) (node.name.map Node.text |>.getD "")
  else if isElementAccessExpression node then
    idxAcc (node.expression.map (parseExpr ctx) |>.getD hole) (node.arguments.getD 0 default |> parseExpr ctx)
  else if isCallExpression node then
    appE (node.expression.map (parseExpr ctx) |>.getD hole) (node.arguments.map (parseExpr ctx))
  else if isArrowFunction node then
    lamE (parseParams ctx node.parameters)
      (node.body.map (fun b => if isBlock b then parseBlock ctx b .Pure else parseExpr ctx b) |>.getD hole)
  else if isBinaryExpression node then
    let left := node.left.map (parseExpr ctx) |>.getD hole
    let right := node.right.map (parseExpr ctx) |>.getD hole
    let opKind := node.operatorToken.map Node.kind |>.getD .Unknown
    if opKind == .EqualsToken then assignE left.name right
    else if isCompoundAssign opKind then assignE left.name (binOpE (compoundOp opKind) left right)
    else binOpE (tsBinOp opKind) left right
  else if isPrefixUnaryExpression node then
    let operand := node.operand.map (parseExpr ctx) |>.getD hole
    let opKind := node.operatorToken.map Node.kind |>.getD .Unknown
    unOpE (if opKind == .ExclamationToken then "Not" else if opKind == .MinusToken then "Neg" else "BitNot") operand
  else if isConditionalExpression node then
    ifE (node.condition.map (parseExpr ctx) |>.getD (litBoolE true))
        (node.thenStatement.map (parseExpr ctx) |>.getD hole)
        (node.elseStatement.map (parseExpr ctx) |>.getD hole)
  else if isObjectLiteralExpression node then
    structLitE (node.members.filterMap fun m =>
      let nm := m.name.map Node.text |>.getD ""
      if nm != "" then some (nm, m.initializer.map (parseExpr ctx) |>.getD hole) else none)
  else if isArrayLiteralExpression node then arrayLitE (node.arguments.map (parseExpr ctx))
  else if isTemplateExpression node then
    (node.templateSpans.map (parseExpr ctx)).foldl (fun acc p => binOpE "Concat" acc p) (litStr "")
  else if isAwaitExpression node then awaitE (node.expression.map (parseExpr ctx) |>.getD hole)
  else if node.kind == .AsExpression then node.expression.map (parseExpr ctx) |>.getD hole
  else if isSpreadElement node then node.expression.map (parseExpr ctx) |>.getD hole
  else hole

partial def parseBlock (ctx : ParserCtxState) (block : Node) (eff : Effect) : IRExpr :=
  parseStmts ctx block.statements eff

partial def parseStmts (ctx : ParserCtxState) (stmts : Array Node) (eff : Effect) : IRExpr :=
  if stmts.size == 0 then litUnit
  else parseStmt ctx stmts[0]! (stmts.extract 1 stmts.size) eff

partial def parseStmt (ctx : ParserCtxState) (stmt : Node) (rest : Array Node) (eff : Effect) : IRExpr :=
  let cont := fun () => parseStmts ctx rest eff
  if isVariableStatement stmt then
    stmt.statements.foldr (fun d body =>
      letE (d.name.map Node.text |>.getD "_") (d.initializer.map (parseExpr ctx) |>.getD hole) body) (cont ())
  else if isReturnStatement stmt then
    let value := stmt.expression.map (parseExpr ctx) |>.getD litUnit
    if eff == .Pure then value else retE value
  else if isIfStatement stmt then
    let cond := stmt.condition.map (parseExpr ctx) |>.getD (litBoolE true)
    let thenB := stmt.thenStatement.map (fun b => parseBlock ctx b eff) |>.getD litUnit
    let elseB := stmt.elseStatement.map (fun b => parseBlock ctx b eff)
    if branchReturns thenB then ifE cond thenB (elseB.getD (cont ()))
    else seq (ifE cond thenB (elseB.getD litUnit)) (cont ())
  else if isForStatement stmt || isWhileStatement stmt then
    let condExpr := stmt.condition.map (parseExpr ctx) |>.getD (litBoolE true)
    let body := stmt.body.map (fun b => parseBlock ctx b eff) |>.getD litUnit
    let loopBody := ifE condExpr (seq body (appE (varE "_loop") #[litUnit])) litUnit
    seq (letE "_loop" (lamE #[{name := "_", type := .Unit, implicit := none, default_ := none}] loopBody)
        (appE (varE "_loop") #[litUnit])) (cont ())
  else if isSwitchStatement stmt then
    let scrutinee := stmt.expression.map (parseExpr ctx) |>.getD hole
    let cases := stmt.clauses.filterMap fun cl =>
      if cl.kind == .CaseClause then
        some (IRCase.mk (cl.expression.map (fun e => toString (repr (exprToPat (parseExpr ctx e)))) |>.getD "")
              none (parseStmts ctx cl.statements .Pure))
      else if cl.kind == .DefaultClause then
        some (IRCase.mk "" none (parseStmts ctx cl.statements .Pure))
      else none
    seq (matchE scrutinee cases) (cont ())
  else if isThrowStatement stmt then
    seq (throwE (stmt.expression.map (parseExpr ctx) |>.getD (litStr "error"))) (cont ())
  else if isTryStatement stmt then
    let tryBody := stmt.block.map (fun b => parseBlock ctx b eff) |>.getD hole
    let handler := stmt.catchClause.bind (fun cc => cc.block.map (fun b => parseBlock ctx b eff)) |>.getD hole
    seq (tryCatchE tryBody handler) (cont ())
  else if isBlock stmt then seq (parseBlock ctx stmt eff) (cont ())
  else if isExpressionStatement stmt then
    seq (stmt.expression.map (parseExpr ctx) |>.getD litUnit) (cont ())
  else cont ()

partial def parseStatement (ctx : ParserCtxState) (stmt : Node) : Option (Array IRDecl) :=
  if isFunctionDeclaration stmt then
    let name := stmt.name.map Node.text |>.getD "_anon"
    let tps := extractTypeParams stmt
    let ps := parseParams ctx stmt.parameters
    let retTy := mapType (ctx.checker.getTypeAtLocation stmt) ctx.checker
    let eff := inferNodeEffect "" ""
    let body := stmt.body.map (fun b => parseBlock ctx b eff) |>.getD hole
    some #[.FuncDef name tps ps retTy eff body none none none none]
  else if isClassDeclaration stmt then
    let name := stmt.name.map Node.text |>.getD "_Class"
    let tps := extractTypeParams stmt
    let fields := stmt.members.filterMap fun m =>
      if isPropertyDeclaration m || isPropertySignature m then some (m.name.map Node.text |>.getD "") else none
    some #[.StructDef name tps fields none none none]
  else if isInterfaceDeclaration stmt then
    let name := stmt.name.map Node.text |>.getD "_Iface"
    let tps := extractTypeParams stmt
    let fields := stmt.members.filterMap fun m =>
      if isPropertySignature m then some (m.name.map Node.text |>.getD "") else none
    some #[.StructDef name tps fields none none none]
  else if isTypeAliasDeclaration stmt then
    let name := stmt.name.map Node.text |>.getD "_Alias"
    let tps := extractTypeParams stmt
    let body := mapType (ctx.checker.getTypeAtLocation stmt) ctx.checker
    some #[.TypeAlias name tps body none]
  else if isEnumDeclaration stmt then
    let name := stmt.name.map Node.text |>.getD "_Enum"
    let members := stmt.members.map fun m => m.name.map Node.text |>.getD "_"
    some #[.InductiveDef name #[] members none]
  else if isVariableStatement stmt then
    some (stmt.statements.filterMap fun d =>
      if isVariableDeclaration d then
        some (.VarDecl (d.name.map Node.text |>.getD "_")
          (mapType (ctx.checker.getTypeAtLocation d) ctx.checker)
          (d.initializer.map (parseExpr ctx) |>.getD hole) false)
      else none)
  else none

end  -- mutual

-- ─── Module entry point ─────────────────────────────────────────────────────────

def parseFile (opts : ParseOptions) : IRModule :=
  let ctx : ParserCtxState := { needsDO := hasDOPattern (opts.sourceText.getD "") }
  let decls := ctx.sf.statements.foldl (fun acc stmt =>
    match parseStatement ctx stmt with
    | some ds => acc ++ ds
    | none    => acc) #[]
  { name       := fileToModuleName ctx.sf.fileName
  , imports    := ctx.imports
  , decls      := decls
  , comments   := #[]
  , sourceFile := some (some ctx.sf.fileName) }

def tsModToLean (spec : String) : String :=
  if !(spec.startsWith ".") then
    match spec with | "zod" => "TSLean.Stdlib.Validation" | "uuid" => "TSLean.Stdlib.Uuid"
                    | _ => "TSLean.External." ++ cap spec
  else "TSLean.Generated." ++ ".".intercalate (spec.splitOn "/" |>.filter (· != "") |>.map cap)

def leadingComment    (_n : Node) (_s : SourceFile) : Option String := none
def jsdocComment      (_n : Node) (_s : SourceFile) : Option String := none
def hasIndexSignature (_n : Node) (_c : TypeChecker) : Bool := false


    let struct : IRDecl := { tag := "StructDef", name := name, typeParams := typeParams, fields := default, deriving := #["Repr", "BEq"], comment := comment, extends_ := extendsNames.getD 0 default }
    decls.push struct
    if decls.size == 1 then
      decls.getD 0 default
    else
      decls

def ParserCtx.parseTypeAlias (self : ParserCtxState) (node : TypeAliasDeclaration) : String :=
  let name : String := node.name.text
  let tps : Array String := extractTypeParams node
  let ty : Type := self.checker.getTypeAtLocation node
  if ty.isUnion then
    let disc : Option DiscriminantInfo := detectDiscriminatedUnion ty self.checker
    if disc then
      { tag := "InductiveDef", name := name, typeParams := tps, ctors := default, comment := leadingComment node self.sf }
    else
      let members : Array Type := ty.types
      if members.every (fun m => m.flags &&& ts.TypeFlags.StringLiteral) then
        { tag := "InductiveDef", name := name, typeParams := tps, ctors := default, comment := leadingComment node self.sf }
      else
        ()
  else
    ()
  if ty.isIntersection then
    let isBranded : Bool := ty.types.some (fun t => (t.flags &&& ts.TypeFlags.Object) && (t.getProperties.some (fun p => (p.name.startsWith "__brand") || (p.name.startsWith "_brand"))))
    if isBranded then
      { tag := "StructDef", name := name, typeParams := tps, fields := #[{ name := "val", type := TyString }], deriving := #["Repr", "BEq", "DecidableEq"] }
    else
      ()
  else
    ()
  let typeNode : TypeNode := node.type
  if typeNode then
    if ts.isConditionalTypeNode typeNode then
      let resolved : IRType := mapType ty self.checker
      { tag := "TypeAlias", name := name, typeParams := tps, body := resolved, comment := "-- conditional type: " ++ (typeNode.getText self.sf) }
    else
      if ts.isMappedTypeNode typeNode then
        let resolved : IRType := mapType ty self.checker
        { tag := "TypeAlias", name := name, typeParams := tps, body := resolved, comment := "-- mapped type: " ++ (typeNode.getText self.sf.substring 0 80) }
      else
        if ts.isTemplateLiteralTypeNode typeNode then
          { tag := "TypeAlias", name := name, typeParams := tps, body := TyString, comment := "-- template literal type: " ++ (typeNode.getText self.sf) }
        else
          if ts.isTupleTypeNode typeNode then
            let elems : Array IRType := typeNode.elements.map (fun e => let elemType : Type := self.checker.getTypeAtLocation e
            mapType elemType self.checker)
            { tag := "TypeAlias", name := name, typeParams := tps, body := TyTuple elems, comment := leadingComment node self.sf }
          else
            if ts.isTypeQueryNode typeNode then
              let resolved : IRType := mapType ty self.checker
              { tag := "TypeAlias", name := name, typeParams := tps, body := resolved, comment := "-- typeof type: " ++ (typeNode.getText self.sf) }
            else
              if (ts.isTypeOperatorNode typeNode) && (typeNode.operator == ts.SyntaxKind.KeyOfKeyword) then
                { tag := "TypeAlias", name := name, typeParams := tps, body := TyString, comment := "-- keyof type" }
              else
                ()
  else
    ()
  { tag := "TypeAlias", name := name, typeParams := tps, body := mapType ty self.checker, comment := leadingComment node self.sf }

def ParserCtx.parseEnum (self : ParserCtxState) (node : EnumDeclaration) : String :=
  let enumName : String := node.name.text
  let members : Array __object := node.members.map (fun m => { name := if ts.isIdentifier m.name then
    m.name.text
  else
    m.name.getText self.sf, value := if m.initializer then
    m.initializer.getText self.sf.replace default ""
  else
    none })
  let isStringEnum : Bool := members.some (fun m => (m.value.isSome) && (Float.isNaN (Number m.value)))
  let inductive : IRDecl := { tag := "InductiveDef", name := enumName, typeParams := #[], ctors := default, comment := leadingComment node self.sf }
  if !isStringEnum then
    «inductive»
  else
    let toStringCases : Array IRCase := members.map (fun m => { pattern := default, body := litStr (Option.getD m.value m.name) })
    let toStringFn : IRDecl := { tag := "FuncDef", name := default, typeParams := #[], params := #[{ name := "e", type := TyRef enumName }], retType := TyString, effect := Pure, body := default }
    #[«inductive», toStringFn]

def ParserCtx.parseVarStmt (self : ParserCtxState) (node : VariableStatement) : Array IRDecl :=
  let isConst : Bool := !(!(node.declarationList.flags &&& ts.NodeFlags.Const))
  let out : Array IRDecl := #[]
  Array.forM node.declarationList.declarations (fun d => if !(ts.isIdentifier d.name) then
    ()
  else
    ()
  let name : String := d.name.text
  let ty : IRType := mapType (self.checker.getTypeAtLocation d) self.checker
  if d.initializer && ((ts.isArrowFunction d.initializer) || (ts.isFunctionExpression d.initializer)) then
    let fn : ArrowFunction := d.initializer
    let tps : Array String := extractTypeParams fn
    let ps : Array IRParam := parseParams self fn.parameters
    let sig : Signature := self.checker.getSignatureFromDeclaration fn
    let ret : IRType := if sig then
      mapType (self.checker.getReturnTypeOfSignature sig) self.checker
    else
      TyUnit
    let eff : Effect := inferNodeEffect fn self.checker
    let body : IRExpr := if ts.isBlock fn.body then
      parseBlock self fn.body eff
    else
      parseExpr self fn.body
    out.push ({ tag := "FuncDef", name := name, typeParams := tps, params := ps, retType := ret, effect := eff, body := body })
  else
    let val : IRExpr := if d.initializer then
      parseExpr self d.initializer
    else
      holeExpr ty
    out.push ({ tag := "VarDecl", name := name, type := ty, value := val, mutable := !isConst }))
  out

def ParserCtx.parseNamespace (self : ParserCtxState) (node : ModuleDeclaration) : IRDecl :=
  let inner : Array IRDecl := #[]
  if node.body && (ts.isModuleBlock node.body) then
    Array.forM node.body.statements (fun s => let d : String := parseStatement self s
    if d then
      if fun______true d then
        inner.push d
      else
        inner.push d
    else
      ())
  else
    ()
  { tag := "Namespace", name := node.name.text, decls := inner }

def ParserCtx.parseBlock (self : ParserCtxState) (block : Block) (eff : Effect) : IRExpr :=
  parseStmts self block.statements eff

def ParserCtx.parseStmts (self : ParserCtxState) (stmts : Array Statement) (eff : Effect) : IRExpr :=
  if stmts.size == 0 then
    litUnit
  else
    let head : Statement := stmts.getD 0 default
    let rest : Array Statement := stmts.getD 1 default
    parseStmt self head rest eff

def ParserCtx.parseStmt (self : ParserCtxState) (stmt : Statement) (rest : Array Statement) (eff : Effect) : StateT ParserCtxState IO IRExpr :=
  do
    let cont : Unit → IRExpr := fun _ => if rest.size > 0 then
      parseStmts self rest eff
    else
      litUnit
    if ts.isReturnStatement stmt then
      let v : IRExpr := if stmt.expression then
        parseExpr self stmt.expression
      else
        litUnit
      pure { tag := "Return", value := v, type := v.type, effect := v.effect }
    else
      do
        if ts.isVariableStatement stmt then
          let decl : VariableDeclaration := stmt.declarationList.declarations.getD 0 default
          if decl && (ts.isIdentifier decl.name) then
            let name : String := decl.name.text
            let ty : IRType := mapType (self.checker.getTypeAtLocation decl) self.checker
            let val : IRExpr := if decl.initializer then
              parseExpr self decl.initializer
            else
              holeExpr ty
            let body : IRExpr := cont
            let combined : Effect := combineEffects #[val.effect, body.effect]
            if (!(isPure val.effect)) && (hasAsync eff) then
              pure { tag := "Bind", name := name, monad := val, body := body, type := body.type, effect := combined }
            else
              pure { tag := "Let", name := name, annot := ty, value := val, body := body, type := body.type, effect := combined }
          else
            if (decl && (ts.isObjectBindingPattern decl.name)) && decl.initializer then
              let rhs : IRExpr := parseExpr self decl.initializer
              let body : IRExpr := cont
              let elems : Array BindingElement := #[decl.name.elements].reverse
              do
                Array.forM elems (fun el => do
                  let propName : String := if el.propertyName then
                  if ts.isIdentifier el.propertyName then
                    el.propertyName.text
                  else
                    el.propertyName.getText self.sf
                else
                  if ts.isIdentifier el.name then
                    el.name.text
                  else
                    s!"_el{el.pos}"
                let bindName : String := if ts.isIdentifier el.name then
                  el.name.text
                else
                  s!"_el{el.pos}"
                let ty : IRType := mapType (self.checker.getTypeAtLocation el.name) self.checker
                let fieldVal : IRExpr := { tag := "FieldAccess", obj := rhs, field := propName, type := ty, effect := rhs.effect }
                let body := { tag := "Let", name := bindName, annot := ty, value := fieldVal, body := body, type := body.type, effect := combineEffects #[rhs.effect, body.effect] })
                return body
            else
              if (decl && (ts.isArrayBindingPattern decl.name)) && decl.initializer then
                let rhs : IRExpr := parseExpr self decl.initializer
                let body : IRExpr := cont
                let elems : Array ArrayBindingElement := #[decl.name.elements].reverse
                do
                  elems.forEach (fun el revIdx => do
                    let idx : Float := (elems.size - 1) - revIdx
                  if ts.isOmittedExpression el then
                    pure ()
                  else
                    let bindName : String := if (ts.isBindingElement el) && (ts.isIdentifier el.name) then
                      el.name.text
                    else
                      s!"_ai{idx}"
                    let ty : IRType := mapType (self.checker.getTypeAtLocation el) self.checker
                    let indexVal : IRExpr := { tag := "IndexAccess", obj := rhs, index := litNat idx, type := ty, effect := rhs.effect }
                    let body := { tag := "Let", name := bindName, annot := ty, value := indexVal, body := body, type := body.type, effect := combineEffects #[rhs.effect, body.effect] })
                  return body
              else
                ()
        else
          ()
        if ts.isIfStatement stmt then
          pure (parseIf self stmt rest eff)
        else
          if ts.isForOfStatement stmt then
            let iter : IRExpr := parseExpr self stmt.expression
            let binding : String := if ts.isVariableDeclarationList stmt.initializer then
              stmt.initializer.declarations.getD 0 default.name.text
            else
              "_x"
            let body : IRExpr := if ts.isBlock stmt.statement then
              parseBlock self stmt.statement eff
            else
              parseStmt self stmt.statement #[] eff
            let loop : IRExpr := { tag := "App", fn := varExpr "Array.forM" (TyFn #[TyArray TyUnit, TyFn #[TyUnit] TyUnit] TyUnit), args := #[iter, { tag := "Lambda", params := #[{ name := binding, type := TyUnit }], body := body, type := TyFn #[TyUnit] TyUnit, effect := body.effect }], type := TyUnit, effect := combineEffects #[iter.effect, body.effect] }
            let c : IRExpr := cont
            pure (if c.tag == "LitUnit" then
              loop
            else
              seq loop c)
          else
            if ts.isForStatement stmt then
              let loop : IRExpr := parseFor self stmt eff
              let c : IRExpr := cont
              pure (if c.tag == "LitUnit" then
                loop
              else
                seq loop c)
            else
              if ts.isForInStatement stmt then
                let obj : IRExpr := parseExpr self stmt.expression
                let binding : String := if ts.isVariableDeclarationList stmt.initializer then
                  stmt.initializer.declarations.getD 0 default.name.text
                else
                  "_k"
                let body : IRExpr := if ts.isBlock stmt.statement then
                  parseBlock self stmt.statement eff
                else
                  parseStmt self stmt.statement #[] eff
                let keysExpr : IRExpr := { tag := "App", fn := varExpr "AssocMap.keys", args := #[obj], type := TyArray TyString, effect := Pure }
                let loop : IRExpr := { tag := "App", fn := varExpr "Array.forM" (TyFn #[TyArray TyString, TyFn #[TyString] TyUnit] TyUnit), args := #[keysExpr, { tag := "Lambda", params := #[{ name := binding, type := TyString }], body := body, type := TyFn #[TyString] TyUnit, effect := body.effect }], type := TyUnit, effect := combineEffects #[obj.effect, body.effect] }
                let c : IRExpr := cont
                pure (if c.tag == "LitUnit" then
                  loop
                else
                  seq loop c)
              else
                if ts.isWhileStatement stmt then
                  let loop : IRExpr := parseWhile self stmt eff
                  let c : IRExpr := cont
                  pure (if c.tag == "LitUnit" then
                    loop
                  else
                    seq loop c)
                else
                  if ts.isThrowStatement stmt then
                    let err : IRExpr := if stmt.expression then
                      parseExpr self stmt.expression
                    else
                      litStr "error"
                    pure { tag := "Throw", error := err, type := TyNever, effect := exceptEffect TyString }
                  else
                    if ts.isTryStatement stmt then
                      pure (parseTry self stmt rest eff)
                    else
                      if ts.isSwitchStatement stmt then
                        let m : IRExpr := parseSwitch self stmt
                        let c : IRExpr := cont
                        pure (if c.tag == "LitUnit" then
                          m
                        else
                          seq m c)
                      else
                        if ts.isBlock stmt then
                          let inner : IRExpr := parseBlock self stmt eff
                          let c : IRExpr := cont
                          pure (if c.tag == "LitUnit" then
                            inner
                          else
                            seq inner c)
                        else
                          if ts.isExpressionStatement stmt then
                            let e : IRExpr := parseExpr self stmt.expression
                            let c : IRExpr := cont
                            pure (if c.tag == "LitUnit" then
                              e
                            else
                              seq e c)
                          else
                            pure (cont)

def ParserCtx.parseIf (self : ParserCtxState) (stmt : IfStatement) (rest : Array Statement) (eff : Effect) : IRExpr :=
  let cond : IRExpr := parseExpr self stmt.expression
  let then_ : IRExpr := if ts.isBlock stmt.thenStatement then
    parseBlock self stmt.thenStatement eff
  else
    parseStmt self stmt.thenStatement #[] eff
  let thenRets : Bool := branchReturns then_
  if thenRets && (rest.size > 0) then
    let else_ : IRExpr := if stmt.elseStatement then
      if ts.isBlock stmt.elseStatement then
        parseBlock self stmt.elseStatement eff
      else
        parseStmt self stmt.elseStatement rest eff
    else
      parseStmts self rest eff
    { tag := "IfThenElse", cond := cond, then := then_, else_ := else_, type := else_.type, effect := combineEffects #[cond.effect, then_.effect, else_.effect] }
  else
    let else_ : IRExpr := if stmt.elseStatement then
      if ts.isBlock stmt.elseStatement then
        parseBlock self stmt.elseStatement eff
      else
        parseStmt self stmt.elseStatement #[] eff
    else
      litUnit
    let ifExpr : IRExpr := { tag := "IfThenElse", cond := cond, then := then_, else_ := else_, type := else_.type, effect := combineEffects #[cond.effect, then_.effect, else_.effect] }
    if rest.size == 0 then
      ifExpr
    else
      let c : IRExpr := parseStmts self rest eff
      seq ifExpr c

def ParserCtx.parseSwitch (self : ParserCtxState) (node : SwitchStatement) : StateT ParserCtxState IO IRExpr :=
  do
    let scrutinee : IRExpr := parseExpr self node.expression
    let cases : Array IRCase := #[]
    let hasDefault : Bool := false
    do
      Array.forM node.caseBlock.clauses (fun cl => do
        if ts.isCaseClause cl then
        let caseExpr : IRExpr := parseExpr self cl.expression
        let pat : IRPattern := exprToPat caseExpr
        let body : IRExpr := parseSwitchCaseBody self cl node.caseBlock.clauses
        cases.push ({ pattern := pat, body := body })
      else
        do
          let hasDefault := true
          let body := parseStmts self cl.statements Pure)
      do
        if (!hasDefault) && (cases.size > 0) then
          let allStringPatterns : Bool := cases.every (fun c => (c.pattern.tag == "PString") || (c.pattern.tag == "PLit"))
          let isDiscriminantSwitch : Bool := (scrutinee.tag == "FieldAccess") && ((((scrutinee.field == "kind") || (scrutinee.field == "type")) || (scrutinee.field == "tag")) || (scrutinee.field == "ok"))
          if !(allStringPatterns && isDiscriminantSwitch) then
            let retType : IRType := Option.getD Option.map (fun _oc => _oc.body) cases.getD 0 default.type TyUnit
            let fallbackBody : IRExpr := if retType.tag == "Unit" then
              litUnit
            else
              holeExpr retType
            cases.push ({ pattern := default, body := fallbackBody })
          else
            ()
        else
          ()
        return { tag := "Match", scrutinee := scrutinee, cases := cases, type := Option.getD Option.map (fun _oc => _oc.body) cases.getD 0 default.type TyUnit, effect := combineEffects (cases.map (fun c => c.body.effect)) }

def ParserCtx.parseSwitchCaseBody (self : ParserCtxState) (cl : CaseClause) (allClauses : NodeArray CaseOrDefaultClause) : StateT ParserCtxState IO IRExpr :=
  do
    let stmts : Array Statement := Array.ofList cl.statements.filter (fun s => (!(ts.isBreakStatement s)) && (!(ts.isContinueStatement s)))
    if stmts.size == 0 then
      let idx : Float := allClauses.indexOf cl
      do
        let _loop_41808 := fun i => if i < allClauses.size then
          let next : CaseOrDefaultClause := allClauses.getD i default
          let nextStmts : Array Statement := Array.ofList next.statements.filter (fun s => (!(ts.isBreakStatement s)) && (!(ts.isContinueStatement s)))
          if nextStmts.size > 0 then
            parseStmts self nextStmts Pure
          else
            ()
          _loop_41808 (i + 1)
        else
          ()
        return litUnit
    else
      pure (parseStmts self stmts Pure)

def ParserCtx.parseTry (self : ParserCtxState) (node : TryStatement) (rest : Array Statement) (eff : Effect) : IRExpr :=
  let body : IRExpr := parseBlock self node.tryBlock eff
  let errName : String := if Option.map (fun _oc => _oc.name) (Option.map (fun _oc => _oc.variableDeclaration) node.catchClause) then
    node.catchClause.variableDeclaration.name.text
  else
    "_e"
  let handler : IRExpr := if Option.map (fun _oc => _oc.block) node.catchClause then
    parseBlock self node.catchClause.block eff
  else
    varExpr errName
  let tryCatch : IRExpr := { tag := "TryCatch", body := body, errName := errName, handler := handler, type := body.type, effect := body.effect }
  if rest.size == 0 then
    tryCatch
  else
    seq tryCatch (parseStmts self rest eff)

def ParserCtx.parseFor (self : ParserCtxState) (node : ForStatement) (eff : Effect) : IRExpr :=
  let init : Option VariableDeclaration := if node.initializer && (ts.isVariableDeclarationList node.initializer) then
    node.initializer.declarations.getD 0 default
  else
    none
  let iName : String := if init && (ts.isIdentifier init.name) then
    init.name.text
  else
    "_i"
  let iVal : IRExpr := if Option.map (fun _oc => _oc.initializer) init then
    parseExpr self init.initializer
  else
    litNat 0
  let cond : IRExpr := if node.condition then
    parseExpr self node.condition
  else
    litBool true
  let body : IRExpr := if ts.isBlock node.statement then
    parseBlock self node.statement eff
  else
    parseStmt self node.statement #[] eff
  let incrParsed : IRExpr := if node.incrementor then
    parseExpr self node.incrementor
  else
    { tag := "BinOp", op := "Add", left := varExpr iName TyNat, right := litNat 1, type := TyNat, effect := Pure }
  let incrArg : IRExpr := if (incrParsed.tag == "Assign") && (incrParsed.target.tag == "Var") then
    incrParsed.value
  else
    incrParsed
  let lName : String := s!"_loop_{node.pos}"
  let recurse : IRExpr := { tag := "App", fn := varExpr lName, args := #[incrArg], type := TyUnit, effect := Pure }
  let loopBody : IRExpr := { tag := "IfThenElse", cond := cond, then := seq body recurse, else_ := litUnit, type := TyUnit, effect := combineEffects #[cond.effect, body.effect] }
  { tag := "Let", name := lName, value := default, body := default, type := TyUnit, effect := body.effect }

def ParserCtx.parseWhile (self : ParserCtxState) (node : WhileStatement) (eff : Effect) : IRExpr :=
  let cond : IRExpr := parseExpr self node.expression
  let body : IRExpr := if ts.isBlock node.statement then
    parseBlock self node.statement eff
  else
    parseStmt self node.statement #[] eff
  let lName : String := s!"_while_{node.pos}"
  let recurse : IRExpr := { tag := "App", fn := varExpr lName, args := #[], type := TyUnit, effect := Pure }
  let lBody : IRExpr := { tag := "IfThenElse", cond := cond, then := seq body recurse, else_ := litUnit, type := TyUnit, effect := combineEffects #[cond.effect, body.effect] }
  { tag := "Let", name := lName, value := default, body := default, type := TyUnit, effect := body.effect }

def ParserCtx.parseExpr (self : ParserCtxState) (node : Expression) : IRExpr :=
  let ty : IRType := mapType (self.checker.getTypeAtLocation node) self.checker
  if ts.isNumericLiteral node then
    let v : Float := Number node.text
    if (Number.isInteger v) && (v >= 0) then
      { tag := "LitNat", value := v, type := TyNat, effect := Pure }
    else
      { tag := "LitFloat", value := v, type := TyFloat, effect := Pure }
  else
    if (ts.isStringLiteral node) || (ts.isNoSubstitutionTemplateLiteral node) then
      litStr node.text
    else
      if ts.isTemplateExpression node then
        parseTemplate self node
      else
        if node.kind == ts.SyntaxKind.TrueKeyword then
          litBool true
        else
          if node.kind == ts.SyntaxKind.FalseKeyword then
            litBool false
          else
            if (node.kind == ts.SyntaxKind.NullKeyword) || (node.kind == ts.SyntaxKind.UndefinedKeyword) then
              { tag := "LitNull", type := TyOption TyUnit, effect := Pure }
            else
              if ts.isIdentifier node then
                varExpr (if node.text == "undefined" then
                  "none"
                else
                  node.text) ty
              else
                if node.kind == ts.SyntaxKind.ThisKeyword then
                  varExpr "self" ty
                else
                  if ts.isPropertyAccessExpression node then
                    parsePropAccess self node ty
                  else
                    if ts.isElementAccessExpression node then
                      let obj : IRExpr := parseExpr self node.expression
                      let index : IRExpr := parseExpr self node.argumentExpression
                      if node.questionDotToken then
                        { tag := "App", fn := varExpr "Array.get?", args := #[obj, index], type := TyOption ty, effect := Pure }
                      else
                        { tag := "IndexAccess", obj := obj, index := index, type := ty, effect := Pure }
                    else
                      if ts.isCallExpression node then
                        parseCall self node ty
                      else
                        if ts.isNewExpression node then
                          parseNew self node ty
                        else
                          if (ts.isArrowFunction node) || (ts.isFunctionExpression node) then
                            parseLambda self node
                          else
                            if ts.isBinaryExpression node then
                              if node.operatorToken.kind == ts.SyntaxKind.InstanceOfKeyword then
                                let expr : IRExpr := parseExpr self node.left
                                let testTy : IRType := mapType (self.checker.getTypeAtLocation node.right) self.checker
                                { tag := "IsType", expr := expr, testType := testTy, type := TyBool, effect := expr.effect }
                              else
                                if node.operatorToken.kind == ts.SyntaxKind.InKeyword then
                                  let key : IRExpr := parseExpr self node.left
                                  let obj : IRExpr := parseExpr self node.right
                                  { tag := "App", fn := varExpr "AssocMap.contains", args := #[obj, key], type := TyBool, effect := Pure }
                                else
                                  if node.operatorToken.kind == ts.SyntaxKind.CommaToken then
                                    let left : IRExpr := parseExpr self node.left
                                    let right : IRExpr := parseExpr self node.right
                                    { tag := "Sequence", stmts := #[left, right], type := right.type, effect := combineEffects #[left.effect, right.effect] }
                                  else
                                    parseBinary self node ty
                            else
                              if ts.isPrefixUnaryExpression node then
                                parsePrefix self node ty
                              else
                                if ts.isPostfixUnaryExpression node then
                                  parsePostfix self node
                                else
                                  if ts.isConditionalExpression node then
                                    let cond : IRExpr := parseExpr self node.condition
                                    let then_ : IRExpr := parseExpr self node.whenTrue
                                    let else_ : IRExpr := parseExpr self node.whenFalse
                                    { tag := "IfThenElse", cond := cond, then := then_, else_ := else_, type := then_.type, effect := combineEffects #[cond.effect, then_.effect, else_.effect] }
                                  else
                                    if ts.isObjectLiteralExpression node then
                                      parseObjLit self node ty
                                    else
                                      if ts.isArrayLiteralExpression node then
                                        let elems : Array IRExpr := node.elements.map (fun e => if ts.isSpreadElement e then
                                          parseExpr self e.expression
                                        else
                                          parseExpr self e)
                                        { tag := "ArrayLit", elems := elems, type := TyArray (Option.getD (Option.map (fun _oc => _oc.type) elems.getD 0 default) TyUnit), effect := combineEffects (elems.map (fun e => e.effect)) }
                                      else
                                        if ts.isAwaitExpression node then
                                          let inner : IRExpr := parseExpr self node.expression
                                          { tag := "Await", expr := inner, type := ty, effect := Async }
                                        else
                                          if (ts.isAsExpression node) || (ts.isTypeAssertionExpression node) then
                                            let inner : IRExpr := parseExpr self node.expression
                                            { tag := "Cast", expr := inner, targetType := ty, type := ty, effect := inner.effect }
                                          else
                                            if ts.isSatisfiesExpression node then
                                              parseExpr self node.expression
                                            else
                                              if ts.isParenthesizedExpression node then
                                                parseExpr self node.expression
                                              else
                                                if ts.isNonNullExpression node then
                                                  parseExpr self node.expression
                                                else
                                                  if ts.isVoidExpression node then
                                                    let inner : IRExpr := parseExpr self node.expression
                                                    if isPure inner.effect then
                                                      litUnit
                                                    else
                                                      seq inner (litUnit)
                                                  else
                                                    if ts.isSpreadElement node then
                                                      parseExpr self node.expression
                                                    else
                                                      if ts.isTypeOfExpression node then
                                                        let inner : IRExpr := parseExpr self node.expression
                                                        { tag := "App", fn := varExpr "TSLean.typeOf", args := #[inner], type := TyString, effect := Pure }
                                                      else
                                                        if ts.isTaggedTemplateExpression node then
                                                          let template : TemplateLiteral := node.template
                                                          if ts.isNoSubstitutionTemplateLiteral template then
                                                            litStr template.text
                                                          else
                                                            if ts.isTemplateExpression template then
                                                              parseTemplate self template
                                                            else
                                                              holeExpr ty
                                                        else
                                                          if ts.isDeleteExpression node then
                                                            litBool true
                                                          else
                                                            if node.kind == ts.SyntaxKind.ObjectLiteralExpression then
                                                              parseObjLit self node ty
                                                            else
                                                              holeExpr ty

def ParserCtx.parsePropAccess (self : ParserCtxState) (node : PropertyAccessExpression) (ty : IRType) : IRExpr :=
  let obj : IRExpr := parseExpr self node.expression
  let field : String := node.name.text
  if node.expression.kind == ts.SyntaxKind.ThisKeyword then
    { tag := "FieldAccess", obj := varExpr "self" obj.type, field := field, type := ty, effect := Pure }
  else
    if ts.isIdentifier node.expression then
      let fullName : String := s!"{node.expression.text}.{field}"
      let global : Option GlobalTx := lookupGlobal fullName
      if global then
        varExpr global.leanExpr ty
      else
        let sym : Option Symbol := self.checker.getSymbolAtLocation node.expression
        if sym && (sym.flags &&& ts.SymbolFlags.Enum) then
          let enumName : String := node.expression.text
          { tag := "CtorApp", ctor := default, args := #[], type := ty, effect := Pure }
        else
          ()
    else
      ()
    if node.questionDotToken then
      let accessor : IRExpr := { tag := "Lambda", params := #[{ name := "_oc", type := obj.type }], body := default, type := TyFn #[obj.type] ty, effect := Pure }
      { tag := "App", fn := varExpr "Option.map", args := #[accessor, obj], type := TyOption ty, effect := obj.effect }
    else
      { tag := "FieldAccess", obj := obj, field := field, type := ty, effect := Pure }

def ParserCtx.parseCall (self : ParserCtxState) (node : CallExpression) (ty : IRType) : StateT ParserCtxState IO IRExpr :=
  do
    if ts.isPropertyAccessExpression node.expression then
      let fullName : String := node.expression.getText self.sf
      let global : Option GlobalTx := lookupGlobal fullName
      if global then
        let args : Array IRExpr := node.arguments.map (fun a => parseExpr self a)
        do
          if global.maxArgs.isSome then
            let args := args.slice 0 global.maxArgs
          else
            ()
          let eff := if global.io then
            IO
          else
            Pure
      else
        pure (parseMethodCall self node node.expression ty)
    else
      do
        if ts.isIdentifier node.expression then
          let global : Option GlobalTx := lookupGlobal node.expression.text
          if global then
            let args : Array IRExpr := node.arguments.map (fun a => parseExpr self a)
            do
              if global.maxArgs.isSome then
                let args := args.slice 0 global.maxArgs
              else
                ()
              let eff := if global.io then
                IO
              else
                Pure
          else
            ()
        else
          ()
        let fn := parseExpr self node.expression

def ParserCtx.parseMethodCall (self : ParserCtxState) (node : CallExpression) (acc : PropertyAccessExpression) (ty : IRType) : IRExpr :=
  let obj : IRExpr := parseExpr self acc.expression
  let method : String := acc.name.text
  let args : Array IRExpr := node.arguments.map (fun a => parseExpr self a)
  let allEff : Effect := combineEffects #[obj.effect, args.map (fun a => a.effect)]
  let storageTarget : Bool := isStorageAccess self acc.expression
  if storageTarget then
    let fn : String := s!"Storage.{method}"
    { tag := "App", fn := varExpr fn, args := #[obj, args], type := ty, effect := Async }
  else
    { tag := "App", fn := default, args := args, type := ty, effect := allEff }

def ParserCtx.isStorageAccess (self : ParserCtxState) (node : Expression) : Bool :=
  let text : String := node.getText self.sf
  ((text.includes ".storage") || (text == "storage")) || (text.includes "this.state.storage")

def ParserCtx.parseNew (self : ParserCtxState) (node : NewExpression) (ty : IRType) : IRExpr :=
  let name : String := node.expression.getText self.sf
  let args : Array IRExpr := Option.getD node.arguments #[].map (fun a => parseExpr self a)
  if name == "Map" then
    varExpr "AssocMap.empty" ty
  else
    if name == "Set" then
      varExpr "AssocSet.empty" ty
    else
      if name == "Array" then
        { tag := "ArrayLit", elems := #[], type := ty, effect := Pure }
      else
        if (name == "Error") || (name.endsWith "Error") then
          { tag := "App", fn := varExpr "TSError.typeError", args := if args.size > 0 then
            #[args.getD 0 default]
          else
            #[litStr "error"], type := ty, effect := Pure }
        else
          if name == "Response" then
            { tag := "App", fn := varExpr "mkResponse", args := args, type := ty, effect := Pure }
          else
            if name == "Promise" then
              holeExpr ty
            else
              if name == "URL" then
                { tag := "App", fn := varExpr "URL.parse", args := args, type := ty, effect := Pure }
              else
                { tag := "CtorApp", ctor := name, args := args, type := ty, effect := combineEffects (args.map (fun a => a.effect)) }

def ParserCtx.parseLambda (self : ParserCtxState) (node : ArrowFunction) : IRExpr :=
  let params : Array IRParam := parseParams self node.parameters
  let eff : Effect := inferNodeEffect node self.checker
  let body : IRExpr := if ts.isBlock node.body then
    parseBlock self node.body eff
  else
    parseExpr self node.body
  let sig : Signature := self.checker.getSignatureFromDeclaration node
  let ret : IRType := if sig then
    mapType (self.checker.getReturnTypeOfSignature sig) self.checker
  else
    body.type
  { tag := "Lambda", params := params, body := body, type := TyFn (params.map (fun p => p.type)) ret eff, effect := eff }

def ParserCtx.parseBinary (self : ParserCtxState) (node : BinaryExpression) (ty : IRType) : IRExpr :=
  let op : BinaryOperator := node.operatorToken.kind
  if (op == ts.SyntaxKind.EqualsToken) || (isCompoundAssign op) then
    let target : IRExpr := parseExpr self node.left
    let rhs : IRExpr := parseExpr self node.right
    let val : IRExpr := if isCompoundAssign op then
      mkBinOp (compoundOp op) target rhs
    else
      rhs
    { tag := "Assign", target := target, value := val, type := TyUnit, effect := stateEffect TyUnit }
  else
    let left : IRExpr := parseExpr self node.left
    let right : IRExpr := parseExpr self node.right
    let irOp : String := tsBinOp op
    if !irOp then
      holeExpr ty
    else
      { tag := "BinOp", op := irOp, left := left, right := right, type := ty, effect := combineEffects #[left.effect, right.effect] }

def ParserCtx.parsePrefix (self : ParserCtxState) (node : PrefixUnaryExpression) (ty : IRType) : IRExpr :=
  let operand : IRExpr := parseExpr self node.operand
  match node.operator with
    | _ => { tag := "UnOp", op := "Not", operand := operand, type := TyBool, effect := operand.effect }
    | _ => { tag := "UnOp", op := "Neg", operand := operand, type := operand.type, effect := operand.effect }
    | _ => { tag := "UnOp", op := "BitNot", operand := operand, type := ty, effect := operand.effect }
    | _ => { tag := "Assign", target := operand, value := mkBinOp "Add" operand (litNat 1), type := TyUnit, effect := stateEffect TyUnit }
    | _ => { tag := "Assign", target := operand, value := mkBinOp "Sub" operand (litNat 1), type := TyUnit, effect := stateEffect TyUnit }
    | _ => operand

def ParserCtx.parsePostfix (self : ParserCtxState) (node : PostfixUnaryExpression) : IRExpr :=
  let operand : IRExpr := parseExpr self node.operand
  if node.operator == ts.SyntaxKind.PlusPlusToken then
    { tag := "Assign", target := operand, value := mkBinOp "Add" operand (litNat 1), type := TyUnit, effect := stateEffect TyUnit }
  else
    { tag := "Assign", target := operand, value := mkBinOp "Sub" operand (litNat 1), type := TyUnit, effect := stateEffect TyUnit }

def ParserCtx.parseObjLit (self : ParserCtxState) (node : ObjectLiteralExpression) (ty : IRType) : IRExpr :=
  let typeName : String := if ty.tag == "TypeRef" then
    ty.name
  else
    if ty.tag == "Structure" then
      ty.name
    else
      "AnonStruct"
  let spreadExprs : Array IRExpr := #[]
  let namedFields : Array String := #[]
  Array.forM node.properties (fun prop => if ts.isPropertyAssignment prop then
    if ts.isComputedPropertyName prop.name then
      let keyExpr : IRExpr := parseExpr self prop.name.expression
      let valExpr : IRExpr := parseExpr self prop.initializer
      namedFields.push ({ name := default, value := default })
    else
      let name : String := if ts.isIdentifier prop.name then
        prop.name.text
      else
        prop.name.getText self.sf
      namedFields.push ({ name := name, value := parseExpr self prop.initializer })
  else
    if ts.isShorthandPropertyAssignment prop then
      let propName : String := prop.name.text
      let propTy : IRType := mapType (self.checker.getTypeAtLocation prop.name) self.checker
      namedFields.push ({ name := propName, value := varExpr propName propTy })
    else
      if ts.isSpreadAssignment prop then
        spreadExprs.push (parseExpr self prop.expression)
      else
        if ts.isMethodDeclaration prop then
          let name : String := if ts.isIdentifier prop.name then
            prop.name.text
          else
            prop.name.getText self.sf
          let body : IRExpr := if prop.body then
            parseBlock self prop.body Pure
          else
            holeExpr TyUnit
          let params : Array IRParam := parseParams self prop.parameters
          namedFields.push ({ name := name, value := default })
        else
          ())
  let allEffect : Effect := combineEffects #[spreadExprs.map (fun e => e.effect), namedFields.map (fun f => f.value.effect)]
  if (spreadExprs.size == 1) && (namedFields.size > 0) then
    { tag := "StructUpdate", base := spreadExprs.getD 0 default, fields := namedFields, type := ty, effect := allEffect }
  else
    if (spreadExprs.size > 1) && (namedFields.size > 0) then
      let mergedBase : IRExpr := spreadExprs.reduce (fun acc e => { tag := "App", fn := varExpr "AssocMap.mergeWith (fun _ b => b)", args := #[acc, e], type := ty, effect := combineEffects #[acc.effect, e.effect] })
      { tag := "StructUpdate", base := mergedBase, fields := namedFields, type := ty, effect := allEffect }
    else
      if (spreadExprs.size > 0) && (namedFields.size == 0) then
        if spreadExprs.size == 1 then
          spreadExprs.getD 0 default
        else
          { tag := "App", fn := varExpr "id", args := spreadExprs, type := ty, effect := allEffect }
      else
        { tag := "StructLit", typeName := typeName, fields := namedFields, type := ty, effect := allEffect }

def ParserCtx.parseTemplate (self : ParserCtxState) (node : TemplateExpression) : IRExpr :=
  let parts : Array IRExpr := #[litStr node.head.text]
  Array.forM node.templateSpans (fun span => parts.push (parseExpr self span.expression)
  parts.push (litStr span.literal.text))
  parts.filter (fun p => !((p.tag == "LitString") && (p.value == ""))).reduce (fun acc p => { tag := "BinOp", op := "Concat", left := acc, right := p, type := TyString, effect := combineEffects #[acc.effect, p.effect] })

-- // ─── Helpers ──────────────────────────────────────────────────────────────────
def seq (a : IRExpr) (b : IRExpr) : IRExpr :=
  if b.tag == "LitUnit" then
    a
  else
    if a.tag == "LitUnit" then
      b
    else
      if a.tag == "Sequence" then
        { tag := "Sequence", stmts := #[a.stmts, b], type := b.type, effect := combineEffects #[a.effect, b.effect] }
      else
        { tag := "Sequence", stmts := #[a, b], type := b.type, effect := combineEffects #[a.effect, b.effect] }

def mkBinOp (op : BinOp) (left : IRExpr) (right : IRExpr) : IRExpr :=
  { tag := "BinOp", op := op, left := left, right := right, type := left.type, effect := Pure }

partial def branchReturns (e : IRExpr) : Bool :=
  if (e.tag == "Return") || (e.tag == "Throw") then
    true
  else
    if e.tag == "Sequence" then
      branchReturns e.stmts.getD (e.stmts.size - 1) default
    else
      if e.tag == "Let" then
        branchReturns e.body
      else
        if e.tag == "IfThenElse" then
          (branchReturns e.then) && (branchReturns e.else_)
        else
          false

def exprToPat (e : IRExpr) : IRPattern :=
  if e.tag == "LitString" then
    { tag := "PString", value := e.value }
  else
    if e.tag == "LitNat" then
      { tag := "PLit", value := e.value }
    else
      if e.tag == "LitBool" then
        { tag := "PLit", value := e.value }
      else
        if e.tag == "LitNull" then
          { tag := "PNone" }
        else
          if e.tag == "Var" then
            { tag := "PVar", name := e.name }
          else
            { tag := "PWild" }

def isCompoundAssign (kind : SyntaxKind) : Bool :=
  (((((((kind == ts.SyntaxKind.PlusEqualsToken) || (kind == ts.SyntaxKind.MinusEqualsToken)) || (kind == ts.SyntaxKind.AsteriskEqualsToken)) || (kind == ts.SyntaxKind.SlashEqualsToken)) || (kind == ts.SyntaxKind.PercentEqualsToken)) || (kind == ts.SyntaxKind.AmpersandEqualsToken)) || (kind == ts.SyntaxKind.BarEqualsToken)) || (kind == ts.SyntaxKind.CaretEqualsToken)

def compoundOp (kind : SyntaxKind) : BinOp :=
  match kind with
    | _ => "Add"
    | _ => "Sub"
    | _ => "Mul"
    | _ => "Div"
    | _ => "Mod"
    | _ => "Add"

def tsBinOp (kind : SyntaxKind) : String :=
  match kind with
    | _ => "Add"
    | _ => "Sub"
    | _ => "Mul"
    | _ => "Div"
    | _ => "Mod"
    | _ => "Eq"
    | _ => "Eq"
    | _ => "Ne"
    | _ => "Ne"
    | _ => "Lt"
    | _ => "Le"
    | _ => "Gt"
    | _ => "Ge"
    | _ => "And"
    | _ => "Or"
    | _ => "NullCoalesce"
    | _ => "BitAnd"
    | _ => "BitOr"
    | _ => "BitXor"
    | _ => "Shl"
    | _ => "Shr"
    | _ => none

def cap (s : String) : String :=
  if s then
    (s.getD 0 default.toUpper) ++ (s.slice 1)
  else
    s

def fileToModuleName (filePath : String) : String :=
  let base : Any := path.basename filePath ".ts"
  let parts : Any := base.split default.map cap
  "TSLean.Generated." ++ (parts.join "")

def leadingComment (node : Node) (sf : SourceFile) : Option String :=
  let ranges : Option (Array CommentRange) := ts.getLeadingCommentRanges (sf.getFullText) (node.getFullStart)
  if !(Option.map (fun _oc => _oc.size) ranges) then
    none
  else
    ranges.map (fun r => sf.getFullText.slice r.pos r.end).join "\n"

/-- Extract JSDoc comment text (/** ... *\/) from a node. Strips @param/@returns/@throws tags — these use a different Lean 4 syntax. Returns just the summary description. -/
def jsdocComment (node : Node) (sf : SourceFile) : Option String :=
  let ranges : Option (Array CommentRange) := ts.getLeadingCommentRanges (sf.getFullText) (node.getFullStart)
  if !(Option.map (fun _oc => _oc.size) ranges) then
    none
  else
    Array.forM ranges (fun r => let text : String := sf.getFullText.slice r.pos r.end
    if text.startsWith "/**" then
      let lines : Array String := text.replace default "".replace default "".split "\n".map (fun l => l.replace default "".trim)
      let descLines : Array String := #[]
      Array.forM lines (fun line => if line.startsWith "@" then
        ()
      else
        ()
      if line then
        descLines.push line
      else
        ())
      let desc : String := descLines.join " ".trim
      desc || none
    else
      ())
    none

/-- Check if a statement has a const/let/var with an interface/object type that acts as index signature -/
def hasIndexSignature (node : Node) (checker : TypeChecker) : Bool :=
  if (!(ts.isInterfaceDeclaration node)) && (!(ts.isTypeLiteralNode node)) then
    false
  else
    let members : NodeArray TypeElement := if ts.isInterfaceDeclaration node then
      node.members
    else
      node.members
    members.some (fun m => ts.isIndexSignatureDeclaration m)

end TSLean.Generated.Index
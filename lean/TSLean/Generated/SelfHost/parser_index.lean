  let comment : Option String := leadingComment node self.sf
  let extendsNames : Array String := #[]
  Array.forM (Option.getD node.heritageClauses #[]) (fun h => Array.forM h.types (fun t => extendsNames.push (t.expression.getText self.sf)))
  let hasIndex : Bool := node.members.some (fun m => ts.isIndexSignatureDeclaration m)
  if hasIndex && (fields.size == 0) then
    let indexSig : Option IndexSignatureDeclaration := node.members.find (fun m => ts.isIndexSignatureDeclaration m)
    let valType : IRType := if Option.map (fun _oc => _oc.type) indexSig then
      mapType (self.checker.getTypeAtLocation indexSig.type) self.checker
    else
      TyRef "Any"
    { tag := "TypeAlias", name := name, typeParams := typeParams, body := TyMap TyString valType, comment := comment }
  else

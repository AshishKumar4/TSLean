    s!"theorem {safeName}_idx_in_bounds (arr : Array α) (idx : Nat) (h : idx < arr.size) : True := trivial"
  | .DivisionSafe =>
    s!"-- Division safety: `{o.funcName}` divisor: {o.detail}\n" ++
    s!"theorem {safeName}_divisor_nonzero (n d : Float) (h : d ≠ 0) : n / d = n / d := rfl"

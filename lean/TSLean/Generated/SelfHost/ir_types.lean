  | .Except _ => true
  | .Combined es => es.any hasExcept
  | _ => false

/-- True when the effect tree contains `IO` (recursively). -/
partial def hasIO : Effect → Bool
  | .IO => true
  | .Combined es => es.any hasIO
  | _ => false


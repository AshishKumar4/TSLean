-- parseAge: validates and parses an age string
def parseAge (input : String) : Except String Float :=
  match input.toNat? with
  | none => .error "age must be a number"
  | some n =>
    let f := Float.ofNat n
    if f < 0 || f > 150 then .error "age must be between 0 and 150"
    else .ok f

-- divide: safe division with error handling
def divide (a b : Float) : Except String Float :=
  if b == 0.0 then .error "Division by zero"
  else .ok (a / b)

-- safeDivide: catches the error and returns Option
def safeDivide (a b : Float) : Option Float :=
  match divide a b with
  | .ok v  => some v
  | .error _ => none

-- validateEmail: basic email validation
def validateEmail (email : String) : Except String String :=
  if !(email.toList.contains '@') then .error "email must contain @"
  else if email.length < 5 then .error "email too short"
  else .ok email


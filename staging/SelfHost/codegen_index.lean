/-- Generate a do-block from DoStmt list. -/
private partial def genDoBlock (stmts : Array DoStmt) (ctx : Effect) (depth : Nat) : String :=
  let inner := String.mk (List.replicate (2 * (depth + 1)) ' ')
  let lines := stmts.toList.map fun s =>
    match s with
    | .DoBind name expr   => s!"{inner}let {name} ← {genExpr expr ctx (depth+1)}"
    | .DoLet name value   => s!"{inner}let {name} := {genExpr value ctx (depth+1)}"
    | .DoExpr expr        => s!"{inner}{genExpr expr ctx (depth+1)}"
    | .DoReturn value     => s!"{inner}return {genExpr value ctx (depth+1)}"
  s!"do\n{"\n".intercalate lines}"

/-- Generate a Lean 4 pattern from an IRPattern. -/
private def genPattern : IRPattern → String
  | .PVar name    => sanitize name
  | .PWild        => "_"
  | .PLit v       => match v with | .inl s => s!"\"{s}\"" | .inr (.inl n) => toString n | .inr (.inr b) => if b then "true" else "false"
  | .PString v    => s!"\"{v}\""
  | .PNone        => ".none"
  | .PSome inner  => s!".some {genPattern inner}"
  | .PCtor ctor args =>
    let localName := if ctor.contains '.' then ctor.splitOn "." |>.getLast! else ctor
    let argStrs := args.toList.map genPattern
    if argStrs.isEmpty then s!".{localName}" else s!".{localName} {" ".intercalate argStrs}"
  | .PTuple elems => s!"({", ".intercalate (elems.toList.map genPattern)})"
  | .PStruct fields => s!"\{ {", ".intercalate (fields.toList.map (fun f => s!"{f.1} := {genPattern f.2}"))} }"
  | .POr pats     => " | ".intercalate (pats.toList.map genPattern)
  | .PAs pat name => s!"{genPattern pat} as {name}"

-- ─── Top-level code generation ─────────────────────────────────────────────────

/-- Generate a complete Lean 4 source file from an IR module. -/
def generateLean (mod : IRModule) : String :=
  let header := s!"{GENERATED_BANNER}\n-- Source: {mod.sourceFile.getD "unknown"}\n"
  let imports := mod.imports.toList.map (fun i => s!"import {i.module}") |> "\n".intercalate
  let body := mod.decls.toList.map genDecl |> "\n\n".intercalate
  s!"{header}\n{imports}\n\nopen TSLean\n\n{body}\n"

/-- Generate a single declaration. -/
private partial def genDecl (d : IRDecl) : String :=
  match d with
  | .FuncDef name typeParams params retType effect body isPartial =>
    let tp := fmtTypeParams typeParams
    let ps := params.toList.map (fun p => s!"({p.name} : {irTypeToLean p.type})") |> " ".intercalate
    let ret := irTypeToLean retType
    let kw := if isPartial then "partial def" else "def"
    let bodyStr := genExpr body effect 1
    s!"{kw} {sanitize name}{tp} {ps} : {ret} :=\n  {bodyStr}"
  | .StructDef name typeParams fields =>
    let tp := fmtTypeParams typeParams
    let fs := fields.toList.map (fun f => s!"  {f.1} : {irTypeToLean f.2}") |> "\n".intercalate
    s!"structure {name}{tp} where\n  mk ::\n{fs}"
  | .InductiveDef name typeParams ctors =>
    let tp := fmtTypeParams typeParams
    let cs := ctors.toList.map (fun c =>
      if c.2.size == 0 then s!"  | {c.1}"
      else s!"  | {c.1} {" ".intercalate (c.2.toList.map (fun t => s!"({irTypeToLean t})"))}")
    s!"inductive {name}{tp} where\n{"\n".intercalate cs}\n  deriving {DEFAULT_DERIVING}"
  | .TypeAlias name typeParams body =>
    s!"abbrev {name}{fmtTypeParams typeParams} := {irTypeToLean body}"
  | .Namespace name decls =>
    let inner := decls.toList.map genDecl |> "\n\n".intercalate
    s!"namespace {name}\n\n{inner}\n\nend {name}"
  | .RawLean code => code
  | .VarDecl name type value mutable =>
    if mutable then s!"-- mutable: {name}\ndef {sanitize name}_ref : IO (IO.Ref {irTypeToLean type}) := IO.mkRef {genExpr value .Pure}"
    else s!"def {sanitize name} : {irTypeToLean type} := {genExpr value .Pure}"
  | .TheoremDef name statement proof =>
    s!"theorem {name} : {statement} := by\n  {proof}"
  | .InstanceDef typeClass typeArgs methods =>
    let tArgs := typeArgs.toList.map irTypeToLean |> " ".intercalate
    let ms := methods.toList.map genDecl |> "\n  ".intercalate
    s!"instance : {typeClass} {tArgs} where\n  {ms}"
  | .ClassDecl name typeParams _supers methods =>
    let ms := methods.toList.map (fun m => s!"  {m.1} : {irTypeToLean m.2}") |> "\n".intercalate
    s!"class {name}{fmtTypeParams typeParams} where\n{ms}"


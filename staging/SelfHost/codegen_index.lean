-- ─── Sanitization ──────────────────────────────────────────────────────────────

/-- Escape Lean 4 keywords with French quotes; replace special chars with _. -/
def sanitize (name : String) : String :=
  if LEAN_KEYWORDS.contains name then s!"«{name}»"
  else name.map (fun c =>
    if c.isAlphanum || c == '_' || c == '.' || c == '!' || c == '?' || c == '\'' then c
    else '_')

/-- Format type parameters as Lean 4 implicit binders: `{T : Type} {U : Type}`. -/
def fmtTypeParams (params : Array String) : String :=
  if params.size == 0 then ""
  else " " ++ (params.toList.map (fun p => s!"\{{p} : Type}")).foldl (· ++ " " ++ ·) "" |>.trimLeft

-- ─── Expression Code Generation ────────────────────────────────────────────────

/-- Check if an expression needs parenthesisation as a function argument. -/
def needsParens (tag : String) : Bool :=
  tag == "App" || tag == "BinOp" || tag == "UnOp" || tag == "IfThenElse" ||
  tag == "Lambda" || tag == "Let" || tag == "Bind" || tag == "TryCatch" ||
  tag == "Match" || tag == "LitFloat"

/-- Generate Lean 4 code for an IR expression. -/
partial def genExpr (e : IRExpr) (ctx : Effect) (depth : Nat := 0) : String :=
  let indent := String.mk (List.replicate (2 * depth) ' ')
  match e with
  | .LitNat v _    => toString v
  | .LitInt v _    => toString v
  | .LitFloat v _  => if v == v.round then s!"({v} : Float)" else toString v
  | .LitString v _ => s!"\"{v}\""
  | .LitBool v _   => if v then "true" else "false"
  | .LitUnit _     => "()"
  | .LitNull _     => "none"
  | .Hole _        => "default"
  | .Var name _    => sanitize name

  | .FieldAccess obj field _ => s!"{genExpr obj ctx depth}.{field}"
  | .IndexAccess obj idx _   => s!"{genExpr obj ctx depth}.getD {genExpr idx ctx depth} default"

  | .Lambda params body _    =>
    let ps := params.toList.map (·.name) |> " ".intercalate
    s!"fun {if ps.isEmpty then "_" else ps} => {genExpr body ctx depth}"

  | .App fn args _           =>
    let fnStr := genExpr fn ctx depth
    let argStrs := args.toList.map (fun a => genExpr a ctx depth)
    if argStrs.isEmpty then fnStr else s!"{fnStr} {" ".intercalate argStrs}"

  | .Let name _ann value body _ =>
    let v := genExpr value ctx depth
    let b := genExpr body ctx depth
    s!"let {name} := {v}\n{indent}{b}"

  | .Bind name monad body _    =>
    let m := genExpr monad ctx depth
    let b := genExpr body ctx depth
    s!"let {name} ← {m}\n{indent}{b}"

  | .IfThenElse cond t e_ _    =>
    let c := genExpr cond ctx depth
    let inner := String.mk (List.replicate (2 * (depth + 1)) ' ')
    s!"if {c} then\n{inner}{genExpr t ctx (depth+1)}\n{indent}else\n{inner}{genExpr e_ ctx (depth+1)}"

  | .Match scr cases _         =>
    let s := genExpr scr ctx depth
    let inner := String.mk (List.replicate (2 * (depth + 1)) ' ')
    let casesStr := cases.toList.map (fun c =>
      let pat := genPattern c.pattern
      let body := genExpr c.body ctx (depth + 1)
      s!"{inner}| {pat} => {body}")
    s!"match {s} with\n{"\n".intercalate casesStr}"

  | .Sequence stmts _          =>
    if stmts.size == 0 then "()"
    else if stmts.size == 1 then genExpr stmts[0]! ctx depth
    else (stmts.toList.map (genExpr · ctx depth)).foldl (· ++ "\n" ++ indent ++ ·) "" |>.trimLeft

  | .StructLit _typeName fields _ =>
    let fs := fields.toList.map (fun f => s!"{f.1} := {genExpr f.2 ctx depth}")
    s!"\{ {", ".intercalate fs} }"

  | .StructUpdate base fields _ =>
    let b := genExpr base ctx depth
    let fs := fields.toList.map (fun f => s!"{f.1} := {genExpr f.2 ctx depth}")
    s!"\{ {b} with {", ".intercalate fs} }"

  | .CtorApp ctor args _       =>
    let argStrs := args.toList.map (genExpr · ctx depth)
    if argStrs.isEmpty then sanitize ctor else s!"{sanitize ctor} {" ".intercalate argStrs}"

  | .ArrayLit elems _          =>
    s!"#[{", ".intercalate (elems.toList.map (genExpr · ctx depth))}]"

  | .TupleLit elems _          =>
    s!"({", ".intercalate (elems.toList.map (genExpr · ctx depth))})"

  | .Pure_ value _             => s!"pure {genExpr value ctx depth}"
  | .StateGet _                => "get"
  | .StateSet value _          => s!"set {genExpr value ctx depth}"
  | .Throw err _               => s!"throw {genExpr err ctx depth}"

  | .TryCatch body errName handler _ =>
    let b := genExpr body ctx depth
    let h := genExpr handler ctx depth
    s!"tryCatch ({b}) (fun {errName} => {h})"

  | .Await expr _              => genExpr expr ctx depth
  | .Cast expr _               => genExpr expr ctx depth
  | .TypeNarrow expr _ _ _     => genExpr expr ctx depth
  | .OptChain expr _           => genExpr expr ctx depth
  | .Labeled _label body _     => genExpr body ctx depth

  | .Assign target value _     =>
    let val := genExpr value ctx depth
    match target with
    | .FieldAccess obj field _ =>
      if match obj with | .Var n _ => n == "self" | _ => false then
        s!"modify (fun s => \{ s with {field} := {val} })"
      else s!"-- assign: {genExpr target ctx depth} := {val}"
    | .Var name _ => s!"let {name} := {val}"
    | _ => s!"-- assign: {genExpr target ctx depth} := {val}"

  | .BinOp op left right _    =>
    let l := genExpr left ctx depth
    let r := genExpr right ctx depth
    let opStr := match op with
      | "Add" => if match left.nodeType with | .String => true | _ => false then "++" else "+"
      | "Sub" => "-" | "Mul" => "*" | "Div" => "/" | "Mod" => "%"
      | "Eq" => "==" | "Ne" => "!=" | "Lt" => "<" | "Le" => "≤"
      | "Gt" => ">" | "Ge" => "≥" | "And" => "&&" | "Or" => "||"
      | "Concat" => "++" | "NullCoalesce" => ""
      | _ => "+"
    if op == "NullCoalesce" then s!"Option.getD ({l}) ({r})"
    else s!"({l}) {opStr} ({r})"

  | .UnOp op operand _         =>
    let o := genExpr operand ctx depth
    let opStr := match op with | "Not" => "!" | "Neg" => "-" | _ => "~~~"
    s!"{opStr}({o})"

  | .Return value _            =>
    let v := genExpr value ctx depth
    match ctx with | .Pure => v | _ => s!"pure {v}"

  | .Panic msg _               => s!"panic! \"{msg}\""

  | .MultiLet bindings body _  =>
    let lets := bindings.toList.map (fun b =>
      s!"let {b.name} : {irTypeToLean b.type} := {genExpr b.value ctx depth}")
    let b := genExpr body ctx depth
    ("\n" ++ indent).intercalate (lets ++ [b])

  | .IsType _ _ _              => "True.intro"
  | .YieldExpr value _         => s!"yield {match value with | some v => genExpr v ctx depth | none => "()"}"
  | .DoBlock stmts _           => genDoBlock stmts ctx depth
  | .Break _ _                 => "-- break"
  | .Continue _ _              => "-- continue"
  | .TypeApp fn targs _        =>
    let f := genExpr fn ctx depth
    let ts := targs.toList.map (fun t => s!"({irTypeToLean t})")
    s!"{f} {" ".intercalate ts}"

where

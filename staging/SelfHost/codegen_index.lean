    | .LitUnit n | .LitNull n | .Hole n | .Var _ n
    | .FieldAccess _ _ n | .IndexAccess _ _ n
    | .Lambda _ _ n | .App _ _ n | .TypeApp _ _ n
    | .Let _ _ _ _ n | .Bind _ _ _ n
    | .IfThenElse _ _ _ n | .Match _ _ n | .Sequence _ n
    | .StructLit _ _ n | .StructUpdate _ _ n | .CtorApp _ _ n
    | .ArrayLit _ n | .TupleLit _ n
    | .DoBlock _ n | .Pure_ _ n | .StateGet n | .StateSet _ n
    | .Throw _ n | .TryCatch _ _ _ n | .Await _ n | .Assign _ _ n
    | .BinOp _ _ _ n | .UnOp _ _ n | .Cast _ n | .IsType _ _ n
    | .Return _ n | .Panic _ n
    | .TypeNarrow _ _ _ n | .YieldExpr _ n | .OptChain _ n

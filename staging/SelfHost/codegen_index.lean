/-- Lean 4 keywords that must be escaped with French quotes «». -/
def LEAN_KEYWORDS : Array String := #[
  "def", "fun", "let", "in", "if", "then", "else", "match", "with", "do",
  "return", "where", "have", "show", "from", "by", "class", "instance",
  "structure", "inductive", "namespace", "end", "open", "import", "theorem",
  "lemma", "example", "variable", "universe", "abbrev", "opaque", "partial",
  "mutual", "private", "protected", "section", "attribute", "and", "or",
  "not", "true", "false", "Type", "Prop"
]


  let recurse := { tag := "App", fn := toString (varExpr lName), args := toString #[incrArg], type := TyUnit, effect := Pure }
  let loopBody := { tag := "IfThenElse", cond := toString cond, «then» := toString (seq body recurse), else_ := toString litUnit, type := TyUnit, effect := combineEffects #[cond.effect, body.effect] }
  { tag := "Let", name := lName, value := default, body := default, type := TyUnit, effect := body.effect }

def ParserCtx.parseWhile (self : ParserCtxState) (node : WhileStatement) (eff : Effect) : String :=
  let cond := parseExpr self node.expression
  let body := if sorry then
    parseBlock self node.statement eff
  else
    parseStmt self node.statement #[] eff
  let lName := s!"_while_{node.pos}"
  let recurse := { tag := "App", fn := toString (varExpr lName), args := toString #[], type := TyUnit, effect := Pure }
  let lBody := { tag := "IfThenElse", cond := toString cond, «then» := toString (seq body recurse), else_ := toString litUnit, type := TyUnit, effect := combineEffects #[cond.effect, body.effect] }
  { tag := "Let", name := lName, value := default, body := default, type := TyUnit, effect := body.effect }

def ParserCtx.parseExpr (self : ParserCtxState) (node : String) : String :=
  let ty := default /- cross-file: mapType -/
  if sorry then
    let v : Float := Number node.text
    if (sorry) && (v >= 0) then
      { tag := "LitNat", value := toString v, type := TyNat, effect := Pure }
    else
      { tag := "LitFloat", value := toString v, type := TyFloat, effect := Pure }
  else
    if (sorry) || (sorry) then
      litStr node.text
    else
      if sorry then
        parseTemplate self node
      else
        if node.kind == ts.SyntaxKind.TrueKeyword then
          litBool true
        else
          if node.kind == ts.SyntaxKind.FalseKeyword then
            litBool false
          else
            if (node.kind == ts.SyntaxKind.NullKeyword) || (node.kind == ts.SyntaxKind.UndefinedKeyword) then
              { tag := "LitNull", type := TyOption TyUnit, effect := Pure }
            else
              if sorry then
                varExpr (if node.text == "undefined" then
                  "none"
                else
                  node.text) ty
              else
                if node.kind == ts.SyntaxKind.ThisKeyword then
                  varExpr "self" ty
                else
                  if sorry then
                    parsePropAccess self node ty
                  else
                    if sorry then
                      let obj := parseExpr self node.expression
                      let index := parseExpr self node.argumentExpression
                      if default then
                        { tag := "App", fn := toString (varExpr "Array.get?"), args := toString (#[obj, index]), type := TyOption ty, effect := Pure }
                      else
                        { tag := "IndexAccess", obj := toString obj, index := toString index, type := ty, effect := Pure }
                    else
                      if sorry then
                        parseCall self node ty
                      else
                        if sorry then
                          parseNew self node ty
                        else
                          if (sorry) || (sorry) then
                            parseLambda self node
                          else
                            if sorry then
                              if node.operatorToken.kind == ts.SyntaxKind.InstanceOfKeyword then
                                let expr := parseExpr self node.left
                                let testTy := default /- cross-file: mapType -/
                                { tag := "IsType", expr := toString expr, testType := toString testTy, type := TyBool, effect := expr.effect }
                              else
                                if node.operatorToken.kind == ts.SyntaxKind.InKeyword then
                                  let key := parseExpr self node.left
                                  let obj := parseExpr self node.right
                                  { tag := "App", fn := toString (varExpr "AssocMap.contains"), args := toString (#[obj, key]), type := TyBool, effect := Pure }
                                else
                                  if node.operatorToken.kind == ts.SyntaxKind.CommaToken then
                                    let left := parseExpr self node.left
                                    let right := parseExpr self node.right
                                    { tag := "Sequence", stmts := toString (#[left, right]), type := right.type, effect := combineEffects #[left.effect, right.effect] }
                                  else
                                    parseBinary self node ty
                            else
                              if sorry then
                                parsePrefix self node ty
                              else
                                if sorry then
                                  parsePostfix self node
                                else
                                  if sorry then
                                    let cond := parseExpr self node.condition
                                    let then_ := parseExpr self node.whenTrue
                                    let else_ := parseExpr self node.whenFalse
                                    { tag := "IfThenElse", cond := toString cond, «then» := toString then_, else_ := toString else_, type := then_.type, effect := combineEffects #[cond.effect, then_.effect, else_.effect] }
                                  else
                                    if sorry then
                                      parseObjLit self node ty
                                    else
                                      if sorry then
                                        let elems : Array IRExpr := sorry
                                        { tag := "ArrayLit", elems := toString elems, type := TyArray (Option.getD (sorry) TyUnit), effect := combineEffects (Array.map (fun e => e.effect) elems) }
                                      else
                                        if sorry then
                                          let inner := parseExpr self node.expression
                                          { tag := "Await", expr := toString inner, type := ty, effect := Async }
                                        else
                                          if (sorry) || (sorry) then
                                            let inner := parseExpr self node.expression
                                            { tag := "Cast", expr := toString inner, targetType := ty, type := ty, effect := inner.effect }
                                          else
                                            if sorry then
                                              parseExpr self node.expression
                                            else
                                              if sorry then
                                                parseExpr self node.expression
                                              else
                                                if sorry then
                                                  parseExpr self node.expression
                                                else
                                                  if sorry then
                                                    let inner := parseExpr self node.expression
                                                    if isPure inner.effect then
                                                      litUnit
                                                    else
                                                      seq inner (litUnit)
                                                  else
                                                    if sorry then
                                                      parseExpr self node.expression
                                                    else
                                                      if sorry then
                                                        let inner := parseExpr self node.expression
                                                        { tag := "App", fn := toString (varExpr "TSLean.typeOf"), args := toString #[inner], type := TyString, effect := Pure }
                                                      else
                                                        if sorry then
                                                          let template : TemplateLiteral := node.template
                                                          if sorry then
                                                            litStr template.text
                                                          else
                                                            if sorry then
                                                              parseTemplate self template
                                                            else
                                                              holeExpr ty
                                                        else
                                                          if sorry then
                                                            litBool true
                                                          else
                                                            if sorry then
                                                              litStr node.text
                                                            else
                                                              if node.kind == ts.SyntaxKind.ObjectLiteralExpression then
                                                                parseObjLit self node ty
                                                              else
                                                                holeExpr ty

def ParserCtx.parsePropAccess (self : ParserCtxState) (node : String) (ty : String) : String :=
  let obj := parseExpr self node.expression
  let field := node.name.text
  if node.expression.kind == ts.SyntaxKind.ThisKeyword then
    { tag := "FieldAccess", obj := toString (varExpr "self" obj.type), field := field, type := ty, effect := Pure }
  else
    if sorry then
      let fullName := s!"{node.expression.text}.{field}"
      let global : Option GlobalTx := default /- cross-file: lookupGlobal -/
      if global then
        varExpr global.leanExpr ty
      else
        let sym : Option Symbol := sorry
        if sym && (sym.flags &&& ts.SymbolFlags.Enum) then
          let enumName := node.expression.text
          { tag := "CtorApp", ctor := default, args := toString #[], type := ty, effect := Pure }
        else
          ()
    else
      ()
    if node.questionDotToken then
      let fieldAccess := { tag := "FieldAccess", obj := toString (varExpr "_oc" obj.type), field := field, type := ty, effect := Pure }
      let lambdaBody := if default == "Option" then
        fieldAccess
      else
        { tag := "App", fn := toString (varExpr "some"), args := toString #[fieldAccess], type := TyOption ty, effect := Pure }
      let accessor := { tag := "Lambda", params := toString (#[{ name := "_oc", type := obj.type }]), body := lambdaBody, type := TyFn #[obj.type] (TyOption ty), effect := Pure }
      { tag := "App", fn := default, args := toString #[accessor], type := TyOption ty, effect := obj.effect }
    else
      { tag := "FieldAccess", obj := toString obj, field := field, type := ty, effect := Pure }

def ParserCtx.parseCall (self : ParserCtxState) (node : String) (ty : String) : StateT ParserCtxState IO String :=
  do
    if sorry then
      let fullName := sorry
      let global : Option GlobalTx := default /- cross-file: lookupGlobal -/
      if global then
        let args : Array IRExpr := sorry
        do
          if global.maxArgs.isSome then
            let args := sorry
          else
            let eff : Effect := if global.io then
              IO
            else
              Pure
            pure { tag := "App", fn := toString (varExpr global.leanExpr (TyFn (Array.map (fun a => a.type) args) ty eff)), args := args.tag, type := ty, effect := combineEffects #[eff] ++ (Array.map (fun a => a.effect) args) }
      else
        pure (parseMethodCall self node node.expression ty)
    else do
        if sorry then
          let global : Option GlobalTx := default /- cross-file: lookupGlobal -/
          if global then
            let args : Array IRExpr := sorry
            do
              if global.maxArgs.isSome then
                let args := sorry
              else
                let eff : Effect := if global.io then
                  IO
                else
                  Pure
                pure { tag := "App", fn := toString (varExpr global.leanExpr (TyFn (Array.map (fun a => a.type) args) ty eff)), args := args.tag, type := ty, effect := combineEffects #[eff] ++ (Array.map (fun a => a.effect) args) }
          else
            pure ()
        else
          let fn := parseExpr self node.expression
          let args : Array IRExpr := sorry
          pure { tag := "App", fn := fn.tag, args := args.tag, type := ty, effect := combineEffects #[fn.effect] ++ (Array.map (fun a => a.effect) args) }

def ParserCtx.parseMethodCall (self : ParserCtxState) (node : String) (acc : String) (ty : String) : String :=
  let obj := parseExpr self acc.expression
  let method := acc.name.text
  let args : Array IRExpr := sorry
  let allEff : Effect := combineEffects #[obj.effect] ++ (Array.map (fun a => a.effect) args)
  let storageTarget : Bool := isStorageAccess self acc.expression
  if storageTarget then
    let fn := s!"Storage.{method}"
    { tag := "App", fn := toString (varExpr fn), args := toString (#[obj, args]), type := ty, effect := Async }
  else
    { tag := "App", fn := default, args := args.tag, type := ty, effect := allEff }

def ParserCtx.isStorageAccess (self : ParserCtxState) (node : String) : Bool :=
  let text := sorry
  ((text.includes ".storage") || (text == "storage")) || (text.includes "this.state.storage")

def ParserCtx.parseNew (self : ParserCtxState) (node : NewExpression) (ty : String) : String :=
  let name := sorry
  let args : Array IRExpr := Array.map (fun a => parseExpr self a) (Option.getD node.arguments #[])
  if name == "Map" then
    varExpr "AssocMap.empty" ty
  else
    if name == "Set" then
      varExpr "AssocSet.empty" ty
    else
      if name == "Array" then
        { tag := "ArrayLit", elems := toString #[], type := ty, effect := Pure }
      else
        if (name == "Error") || (name.endsWith "Error") then
          { tag := "App", fn := toString (varExpr "TSError.typeError"), args := toString (if args.size > 0 then
            #[args.getD 0 default]
          else
            #[litStr "error"]), type := ty, effect := Pure }
        else
          if name == "Response" then
            { tag := "App", fn := toString (varExpr "mkResponse"), args := args.tag, type := ty, effect := Pure }
          else
            if name == "Promise" then
              holeExpr ty
            else
              if name == "URL" then
                { tag := "App", fn := toString (varExpr "URL.parse"), args := args.tag, type := ty, effect := Pure }
              else
                { tag := "CtorApp", ctor := name, args := args.tag, type := ty, effect := combineEffects (Array.map (fun a => a.effect) args) }

def ParserCtx.parseLambda (self : ParserCtxState) (node : ArrowFunction) : String :=
  let params : Array IRParam := parseParams self node.parameters
  let eff : Effect := default /- cross-file: inferNodeEffect -/
  let body := if sorry then
    parseBlock self node.body eff
  else
    parseExpr self node.body
  let sig : Signature := sorry
  let ret := if sig then
    default /- cross-file: mapType -/
  else
    body.type
  { tag := "Lambda", params := toString params, body := body, type := TyFn (Array.map (fun p => p.type) params) ret eff, effect := eff }

def ParserCtx.parseBinary (self : ParserCtxState) (node : String) (ty : String) : String :=
  let op : BinaryOperator := node.operatorToken.kind
  if (op == ts.SyntaxKind.EqualsToken) || (isCompoundAssign op) then
    let target := parseExpr self node.left
    let rhs := parseExpr self node.right
    let val := if isCompoundAssign op then
      mkBinOp (compoundOp op) target rhs
    else
      rhs
    { tag := "Assign", target := toString target, value := toString val, type := TyUnit, effect := stateEffect TyUnit }
  else
    let left := parseExpr self node.left
    let right := parseExpr self node.right
    let irOp := tsBinOp op
    if !irOp then
      holeExpr ty
    else
      { tag := "BinOp", op := toString irOp, left := toString left, right := toString right, type := ty, effect := combineEffects #[left.effect, right.effect] }

def ParserCtx.parsePrefix (self : ParserCtxState) (node : PrefixUnaryExpression) (ty : String) : String :=
  let operand := parseExpr self node.operand
  match node.operator with
    | _ => { tag := "UnOp", op := "Not", operand := toString operand, type := TyBool, effect := operand.effect }
    | _ => { tag := "UnOp", op := "Neg", operand := toString operand, type := operand.type, effect := operand.effect }
    | _ => { tag := "UnOp", op := "BitNot", operand := toString operand, type := ty, effect := operand.effect }
    | _ => { tag := "Assign", target := toString operand, value := toString (mkBinOp "Add" operand (litNat 1)), type := TyUnit, effect := stateEffect TyUnit }
    | _ => { tag := "Assign", target := toString operand, value := toString (mkBinOp "Sub" operand (litNat 1)), type := TyUnit, effect := stateEffect TyUnit }
    | _ => operand

def ParserCtx.parsePostfix (self : ParserCtxState) (node : PostfixUnaryExpression) : String :=
  let operand := parseExpr self node.operand
  if node.operator == ts.SyntaxKind.PlusPlusToken then
    { tag := "Assign", target := toString operand, value := toString (mkBinOp "Add" operand (litNat 1)), type := TyUnit, effect := stateEffect TyUnit }
  else
    { tag := "Assign", target := toString operand, value := toString (mkBinOp "Sub" operand (litNat 1)), type := TyUnit, effect := stateEffect TyUnit }

def ParserCtx.parseObjLit (self : ParserCtxState) (node : ObjectLiteralExpression) (ty : String) : String :=
  default

def ParserCtx.parseTemplate (self : ParserCtxState) (node : TemplateExpression) : String :=
  default

-- // ─── Helpers ──────────────────────────────────────────────────────────────────
def seq (a : String) (b : String) : String :=
  if b.tag == "LitUnit" then
    a
  else
    if a.tag == "LitUnit" then
      b
    else
      if default == "Sequence" then
        { tag := "Sequence", stmts := toString (#[default, b]), type := default, effect := combineEffects #[default, default] }
      else
        { tag := "Sequence", stmts := toString (#[a, b]), type := default, effect := combineEffects #[default, default] }

def mkBinOp (op : BinOp) (left : String) (right : String) : String :=
  { tag := "BinOp", op := toString op, left := toString left, right := toString right, type := left.type, effect := Pure }

partial def branchReturns (e : String) : Bool :=
  if (e.tag == "Return") || (default == "Throw") then
    true
  else
    if default == "Sequence" then
      branchReturns default.getD (default.size - 1) default
    else
      if default == "Let" then
        branchReturns default
      else
        if default == "IfThenElse" then
          (branchReturns default) && (branchReturns default)
        else
          false

def exprToPat (e : String) : String :=
  if e.tag == "LitString" then
    { tag := "PString", value := default }
  else
    if default == "LitNat" then
      { tag := "PLit", value := toString default }
    else
      if default == "LitBool" then
        { tag := "PLit", value := toString default }
      else
        if default == "LitNull" then
          { tag := "PNone" }
        else
          if default == "Var" then
            { tag := "PVar", name := default }
          else
            { tag := "PWild" }

def isCompoundAssign (kind : SyntaxKind) : Bool :=
  (((((((kind == ts.SyntaxKind.PlusEqualsToken) || (kind == ts.SyntaxKind.MinusEqualsToken)) || (kind == ts.SyntaxKind.AsteriskEqualsToken)) || (kind == ts.SyntaxKind.SlashEqualsToken)) || (kind == ts.SyntaxKind.PercentEqualsToken)) || (kind == ts.SyntaxKind.AmpersandEqualsToken)) || (kind == ts.SyntaxKind.BarEqualsToken)) || (kind == ts.SyntaxKind.CaretEqualsToken)

def compoundOp (kind : SyntaxKind) : BinOp :=
  match kind with
    | _ => "Add"
    | _ => "Sub"
    | _ => "Mul"
    | _ => "Div"
    | _ => "Mod"
    | _ => "Add"

def tsBinOp (kind : SyntaxKind) : String :=
  match kind with
    | _ => "Add"
    | _ => "Sub"
    | _ => "Mul"
    | _ => "Div"
    | _ => "Mod"
    | _ => "Eq"
    | _ => "Eq"
    | _ => "Ne"
    | _ => "Ne"
    | _ => "Lt"
    | _ => "Le"
    | _ => "Gt"
    | _ => "Ge"
    | _ => "And"
    | _ => "Or"
    | _ => "NullCoalesce"
    | _ => "BitAnd"
    | _ => "BitOr"
    | _ => "BitXor"
    | _ => "Shl"
    | _ => "Shr"
    | _ => none

def cap (s : String) : String :=
  if s then
    (sorry) ++ (sorry)
  else
    s

def fileToModuleName (filePath : String) : String :=
  let base := sorry
  let parts := sorry
  "TSLean.Generated." ++ (sorry)

def leadingComment (node : String) (sf : String) : Option String :=
  let ranges : Option (Array CommentRange) := sorry
  if !(sorry) then
    none
  else
    String.intercalate "\n" (Array.map (fun r => sorry) ranges)

/-- Extract JSDoc comment text (/** ... *\/) from a node. Strips @param/@returns/@throws tags — these use a different Lean 4 syntax. Returns just the summary description. -/
def jsdocComment (node : String) (sf : String) : Option String :=
  default

/-- Check if a statement has a const/let/var with an interface/object type that acts as index signature -/
def hasIndexSignature (node : String) (checker : String) : Bool :=
  if (!(sorry)) && (!(sorry)) then
    false
  else
    let members : NodeArray TypeElement := if sorry then
      node.members
    else
      node.members
    sorry

